<Page
    x:Class="TsubameViewer.Views.MovieViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TsubameViewer.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="using:Microsoft.Xaml.Interactivity"
      xmlns:myConv="using:TsubameViewer.Views.Converters"
      xmlns:uwpControls="using:CommunityToolkit.WinUI.Controls"
      xmlns:ui="using:CommunityToolkit.WinUI"
      xmlns:myBehaviour="using:TsubameViewer.Views.Behaviors"
      xmlns:uwpUIExtensions="using:CommunityToolkit.WinUI"
      xmlns:uiNavigation="using:TsubameViewer.Views.UINavigation"
      xmlns:domainModels="using:TsubameViewer.Core.Models"
      xmlns:myStateTriggers="using:TsubameViewer.Views.StateTrigger"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      xmlns:i18nExt="using:I18NPortable.Xaml.Extensions"
      xmlns:models="using:TsubameViewer.Core.Models.FolderItemListing"
      xmlns:vm="using:TsubameViewer.ViewModels"
      xmlns:animation="using:CommunityToolkit.WinUI.Animations"
      xmlns:fluentIcon="using:Fluent.Icons"
      xmlns:mediaProps="using:Windows.Media.MediaProperties"
      xmlns:media="using:Windows.UI.Xaml.Media"
      mc:Ignorable="d"
      xmlns:Windows10version1903="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract, 8)"
      xmlns:ctwu="using:CommunityToolkit.WinUI">

  <Page.Resources>
    <Style TargetType="fluentIcon:FluentSymbolIcon">
      <Setter Property="IsTabStop"
              Value="False" />
    </Style>

    <DataTemplate x:Name="TitlebarContent"
                  x:DataType="vm:MovieViewerPageViewModel">
      <uwpControls:DockPanel>
        <StackPanel Orientation="Horizontal"
                    Grid.Column="1"
                    Spacing="4"
                    uwpControls:DockPanel.Dock="Right">
          <ToggleButton IsChecked="{x:Bind IsFavoriteCurrentFolderOrArchive, Mode=TwoWay}"
                        ToolTipService.ToolTip="{i18nExt:Localize Key=Favorite_AddItem}"
                        ToolTipService.Placement="Bottom"
                        ctwu:FrameworkElementExtensions.Cursor="Hand">
            <SymbolIcon Symbol="Favorite"
                        Style="{StaticResource TitlebarSymbolIcon}" />
          </ToggleButton>
          <ToggleButton IsChecked="{x:Bind NowEditTransformMode, Mode=TwoWay}"
                        Style="{StaticResource TitlebarToggleButton}"
                        ToolTipService.ToolTip="{i18nExt:Localize Key=EditViewerTransform}"
                        ToolTipService.Placement="Bottom"
                        AccessKey="A"
                        ctwu:FrameworkElementExtensions.Cursor="Hand">
            <SymbolIcon Symbol="ZoomIn"
                        Style="{StaticResource TitlebarSymbolIcon}">
            </SymbolIcon>
          </ToggleButton>
          <ToggleButton IsChecked="{x:Bind PageSettings.IsPlayerRotateEnabled, Mode=TwoWay}"
                        Style="{StaticResource TitlebarToggleButton}"
                        ToolTipService.ToolTip="{i18nExt:Localize Key=MovieViewer_PlayerRotate}"
                        ToolTipService.Placement="Bottom"
                        AccessKey="R"
                        ctwu:FrameworkElementExtensions.Cursor="Hand">
            <SymbolIcon Symbol="Orientation"
                        Style="{StaticResource TitlebarSymbolIcon}">
            </SymbolIcon>
          </ToggleButton>
          <ToggleButton IsChecked="{x:Bind PageSettings.IsHorizontalMirror, Mode=TwoWay}"
                        Style="{StaticResource TitlebarToggleButton}"
                        ToolTipService.ToolTip="{i18nExt:Localize Key=MovieViewer_IsHorizontalMirror}"
                        ToolTipService.Placement="Bottom"
                        AccessKey="H"
                        ctwu:FrameworkElementExtensions.Cursor="Hand">
            <SymbolIcon Symbol="Sort"
                        Style="{StaticResource TitlebarSymbolIcon}">
              <SymbolIcon.RenderTransform>
                <CompositeTransform Rotation="90" ScaleX="0.7" ScaleY="0.7" />
              </SymbolIcon.RenderTransform>
            </SymbolIcon>
          </ToggleButton>
          <Button Command="{x:Bind ToggleFullScreenCommand}"
                  Style="{StaticResource TitlebarButton}"
                  ToolTipService.ToolTip="{i18nExt:Localize Key=MovieViewer_SC_ToggleFullScreen}"
                  ToolTipService.Placement="Bottom"
                  AccessKey="F"
                  ctwu:FrameworkElementExtensions.Cursor="Hand">
            <SymbolIcon Symbol="FullScreen"
                        Style="{StaticResource TitlebarSymbolIcon}">
            </SymbolIcon>
          </Button>
        </StackPanel>

        <StackPanel Orientation="Horizontal">
        </StackPanel>

      </uwpControls:DockPanel>
    </DataTemplate>

