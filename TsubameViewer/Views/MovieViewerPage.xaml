              BorderBrush="{ThemeResource SystemChromeWhiteColor}"
            Windows10version1903:Translation="0, 0, 8">
        <Windows10version1903:Grid.Shadow>
          <Windows10version1903:ThemeShadow />
        </Windows10version1903:Grid.Shadow>
        <Image x:Name="MovieSeekbarTooltipImage"               
               Stretch="None"/>
        <TextBlock x:Name="MovieSeekbarTooltipNotSupported"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Opacity="0.7"
                   TextWrapping="Wrap"
                   Margin="8 8 8 28"
                   Visibility="Collapsed"
                   />
      </Grid>
      <Border Background="{ThemeResource SystemAltMediumColor}"
              HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              Padding="4 0"
              CornerRadius="4 4 0 0">
        <TextBlock x:Name="MovieSeekbarTooltipText"
                   Text="{x:Bind SeekbarFrameTime, Mode=OneWay, Converter={StaticResource TimeSpanToSimpleTextConverter}}"
                   FontSize="18" />
      </Border>
    </Grid>
  </Grid>
</Page>
