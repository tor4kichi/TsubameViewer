    <local:SecondsToVideoTimeConverter x:Key="SecondsToVideoTimeConverter" />
    <local:ToPlaybackRateConverter x:Key="ToPlaybackRateConverter" />
  </Page.Resources>
  <Grid x:Name="PageRoot">

    <VisualStateManager.VisualStateGroups>

      <!-- プレイヤーコントロールUIの表示状態 -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind IsDisplayControlUI, Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="ImageSelectorContainer.Visibility"
                    Value="Visible" />
            <Setter Target="NeighborsContentButtonsContainer.Visibility"
                    Value="Visible" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind IsDisplayControlUI, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="ImageSelectorContainer.Visibility"
                    Value="Collapsed" />
            <Setter Target="NeighborsContentButtonsContainer.Visibility"
                    Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind _vm.PageSettings.IsMuted, Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="ToggleIsMutedButton.Content">
              <Setter.Value>
                <fluentIcon:FluentSymbolIcon Symbol="SpeakerMute24" />
              </Setter.Value>
            </Setter>
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <ctwu:IsEqualStateTrigger Value="{x:Bind SoundVolume_Display, Mode=OneWay}"
                                     To="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="ToggleIsMutedButton.Content">
              <Setter.Value>
                <fluentIcon:FluentSymbolIcon Symbol="SpeakerMute24" />
              </Setter.Value>
            </Setter>
          </VisualState.Setters>
        </VisualState>

      </VisualStateGroup>

      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind TrueToPlayerPlaying(PlayerState), Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="ControlUI_PlayPauseButton.Content">
              <Setter.Value>
                <SymbolIcon Symbol="Pause" />
              </Setter.Value>
            </Setter>
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind _vm.PageSettings.IsHorizontalMirror, Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="MirrorScaleTransform.ScaleX"
                    Value="-1" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
      
      <!-- スワイプによる操作 -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind _vm.NowEditTransformMode, Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="MySwipeDistanceBehavior.IsEnabled"
                    Value="False" />
            <Setter Target="ScaleBehavior.IsEnabled"
                    Value="True" />
            <Setter Target="TranslationBehavior.IsEnabled"
                    Value="True" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind IsDurationAvairable, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="MySwipeDistanceBehavior.IsEnabled"
                    Value="False" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
      
      <!-- 変形情報の表示 -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind _vm.NowEditTransformMode, Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="PlayerTransformInfoContainer.Visibility"
                    Value="Visible" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>

      <!-- 全画面表示 -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind IsDisplayControlUI, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
          </VisualState.StateTriggers>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind NowFullScreenMode, Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="CloseButtonForFullScreen.Visibility"
                    Value="Visible" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>

    </VisualStateManager.VisualStateGroups>

    <!-- KeyboardAccelarator用のダミー -->
    <Grid Opacity="0"
          x:Name="ShortcutKeyButtonsContainer"
          Height="1"
          Width="1"
          HorizontalAlignment="Right"
          VerticalAlignment="Bottom">
      <Grid.RenderTransform>
        <TranslateTransform X="1" Y="1" />
      </Grid.RenderTransform>
      <Button Command="{x:Bind ToggleDisplayShortcutKeyGuideUICommand}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="F1" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind TogglePlayPauseCommand}"
              Tag="{i18nExt:Localize Key=MovieViewer_SC_TogglePlayPause}"
              x:Name="HiddenPlayPauseButton"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Space" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind BackwardOneFrameCommand}"
              Tag="{i18nExt:Localize Key=MovieViewer_SC_BackwardOneFrame}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="J" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind ForwardOneFrameCommand}"
              Tag="{i18nExt:Localize Key=MovieViewer_SC_ForwardOneFrame}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="K" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind ToggleIsMutedCommand}"
              Tag="{i18nExt:Localize Key=MovieViewer_SC_ToggleIsMuted}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="M" />
        </Button.KeyboardAccelerators>
      </Button>

      <Button Command="{x:Bind TogglePlayerStretchCommand}"
              Tag="{i18nExt:Localize Key=MovieViewer_SC_TogglePlayerStretch}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="A" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind TogglePlayerRotateCommand}"
              Tag="{i18nExt:Localize Key=MovieViewer_SC_TogglePlayerRotate}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="R" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind TogglePlayerMirrorCommand}"
              Tag="{i18nExt:Localize Key=MovieViewer_SC_TogglePlayerMirror}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="H" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button x:Name="ControlUI_RepeatButton"
              Command="{x:Bind ToggleRepeatModeCommand}"
              Tag="{i18nExt:Localize Key=MovieViewer_IsRepeat}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="L" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind ToggleFullScreenCommand}"
              Tag="{i18nExt:Localize Key=MovieViewer_SC_ToggleFullScreen}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="F" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind VolumeChangeCommand}"
              Tag="{i18nExt:Localize Key=MovieViewer_SC_VolumeChangeUp}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.CommandParameter>
          <x:Double>0.05</x:Double>
        </Button.CommandParameter>
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Up" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind VolumeChangeCommand}"
              Tag="{i18nExt:Localize Key=MovieViewer_SC_VolumeChangeDown}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.CommandParameter>
          <x:Double>-0.05</x:Double>
        </Button.CommandParameter>
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Down" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind PlaybackPositionChangeCommand}"
              CommandParameter="{x:Bind PlaybackPositionChangeBackward}"
              Tag="{Binding Source='5', Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='MovieViewer_SC_PlaybackPositionChangeBackward'}">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Left" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind PlaybackPositionChangeCommand}"
              CommandParameter="{x:Bind PlaybackPositionChangeForward}"
              Tag="{Binding Source='5', Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='MovieViewer_SC_PlaybackPositionChangeForward'}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Right" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind SaveCurrentFrameCommand}"
              Tag="{i18nExt:Localize Key=MovieViewer_SC_SaveCurrentFrame}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="S" Modifiers="Control" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind SetPlaybackRateToPrevCommand}"
              Tag="{i18nExt:Localize Key=MovieViewer_SC_SetPlaybackRateToPrev}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Z" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Tag="{i18nExt:Localize Key=MovieViewer_SC_SetPlaybackRateToNext}"
              Command="{x:Bind SetPlaybackRateToNextCommand}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="X" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind SetPlaybackPositionWithPercentCommand}"
              Tag="{Binding Source='0', Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='MovieViewer_SC_SetPlaybackPositionWithPercent'}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.CommandParameter><x:Double>0</x:Double></Button.CommandParameter>
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Number0" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind SetPlaybackPositionWithPercentCommand}"
              Tag="{Binding Source='10', Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='MovieViewer_SC_SetPlaybackPositionWithPercent'}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.CommandParameter>
          <x:Double>10</x:Double>
        </Button.CommandParameter>
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Number1" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind SetPlaybackPositionWithPercentCommand}"
              Tag="{Binding Source='20', Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='MovieViewer_SC_SetPlaybackPositionWithPercent'}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.CommandParameter>
          <x:Double>20</x:Double>
        </Button.CommandParameter>
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Number2" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind SetPlaybackPositionWithPercentCommand}"
              Tag="{Binding Source='30', Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='MovieViewer_SC_SetPlaybackPositionWithPercent'}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.CommandParameter>
          <x:Double>30</x:Double>
        </Button.CommandParameter>
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Number3" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind SetPlaybackPositionWithPercentCommand}"
              Tag="{Binding Source='40', Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='MovieViewer_SC_SetPlaybackPositionWithPercent'}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.CommandParameter>
          <x:Double>40</x:Double>
        </Button.CommandParameter>
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Number4" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind SetPlaybackPositionWithPercentCommand}"
              Tag="{Binding Source='50', Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='MovieViewer_SC_SetPlaybackPositionWithPercent'}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.CommandParameter>
          <x:Double>50</x:Double>
        </Button.CommandParameter>
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Number5" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind SetPlaybackPositionWithPercentCommand}"
              Tag="{Binding Source='60', Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='MovieViewer_SC_SetPlaybackPositionWithPercent'}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.CommandParameter>
          <x:Double>60</x:Double>
        </Button.CommandParameter>
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Number6" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind SetPlaybackPositionWithPercentCommand}"
              Tag="{Binding Source='70', Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='MovieViewer_SC_SetPlaybackPositionWithPercent'}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.CommandParameter>
          <x:Double>70</x:Double>
        </Button.CommandParameter>
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Number7" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind SetPlaybackPositionWithPercentCommand}"
              Tag="{Binding Source='80', Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='MovieViewer_SC_SetPlaybackPositionWithPercent'}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.CommandParameter>
          <x:Double>80</x:Double>
        </Button.CommandParameter>
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Number8" />
        </Button.KeyboardAccelerators>
      </Button>
      <Button Command="{x:Bind SetPlaybackPositionWithPercentCommand}"
              Tag="{Binding Source='90', Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='MovieViewer_SC_SetPlaybackPositionWithPercent'}"
              KeyboardAcceleratorPlacementMode="Hidden">
        <Button.CommandParameter>
          <x:Double>90</x:Double>
        </Button.CommandParameter>
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="Number9" />
        </Button.KeyboardAccelerators>
      </Button>
    </Grid>

    <Grid x:Name="PlayerContainer" HorizontalAlignment="Center" VerticalAlignment="Center">
      <MediaPlayerElement AutoPlay="False"
                          Stretch="Uniform"
                          x:Name="MyMediaPlayerElement"
                          RenderTransformOrigin="0.5, 0.5">
        <UIElement.RenderTransform>
          <TransformGroup>
            <TranslateTransform x:Name="PlayerTranslate" />
            <ScaleTransform x:Name="PlayerScale"
                            ScaleY="{Binding RelativeSource={RelativeSource Mode=Self}, Path=ScaleX}"/>

            <ScaleTransform x:Name="MirrorScaleTransform" />
          </TransformGroup>
        </UIElement.RenderTransform>
      </MediaPlayerElement>
    </Grid>

    <Grid IsHitTestVisible="True"
          Background="Transparent"
          Opacity="0"
          PointerPressed="ControlUIInteractionWall_PointerPressed"
          PointerReleased="ControlUIInteractionWall_PointerReleased"
          PointerWheelChanged="ControlUIInteractionWall_PointerWheelChanged"
          x:Name="ControlUIInteractionWall"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          ctwu:FrameworkElementExtensions.EnableActualSizeBinding="True">
      <i:Interaction.Behaviors>
        <myBehaviour:SwipeDistanceBehavior x:Name="MySwipeDistanceBehavior"   
                                           Invoked="MySwipeDistanceBehavior_Invoked"                                           
                                           XPixelsToOneUnit="8"
                                           YPixelsToOneUnit="16"/>
        <myBehaviour:ScaleManipulationBehavior x:Name="ScaleBehavior"
                                               Max="8"
                                               Min="0.5"
                                               Scale="{x:Bind PlayerScale.ScaleX, Mode=TwoWay}"
                                               IsEnabled="False"/>

        <myBehaviour:TranslationManipulationBehavior x:Name="TranslationBehavior"
                                                     TranslationX="{x:Bind PlayerTranslate.X, Mode=TwoWay}"
                                                     TranslationY="{x:Bind PlayerTranslate.Y, Mode=TwoWay}"
                                                     MaxX="{x:Bind  HalfDouble(ControlUIInteractionWall.(ctwu:FrameworkElementExtensions.ActualWidth)), Mode=OneWay}"
                                                     MinX="{x:Bind  HalfDoubleNegation(ControlUIInteractionWall.(ctwu:FrameworkElementExtensions.ActualWidth)), Mode=OneWay}"
                                                     MaxY="{x:Bind  HalfDouble(ControlUIInteractionWall.(ctwu:FrameworkElementExtensions.ActualHeight)), Mode=OneWay}"
                                                     MinY="{x:Bind  HalfDoubleNegation(ControlUIInteractionWall.(ctwu:FrameworkElementExtensions.ActualHeight)), Mode=OneWay}"
                                                     ParentScale="{x:Bind InverseDouble(PlayerScale.ScaleX), Mode=OneWay}"
                                                     IsEnabled="False"/>
      </i:Interaction.Behaviors>
    </Grid>

    <uwpControls:DockPanel x:Name="NeighborsContentButtonsContainer">
      <animation:Implicit.ShowAnimations>
        <animation:OpacityAnimation To="1"
                                    Duration="0:0:0.125" />
      </animation:Implicit.ShowAnimations>
      <animation:Implicit.HideAnimations>
        <animation:OpacityAnimation To="0"
                                    Duration="0:0:0.175" />
      </animation:Implicit.HideAnimations>

      <Border uwpControls:DockPanel.Dock="Bottom"
              Height="180"/>
      <Grid Height="180" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Visibility="{x:Bind _vm.PrevImageSource, Mode=OneWay, Converter={StaticResource NotNullToVisibleConverter}}"
                    ToolTipService.ToolTip="{x:Bind _vm.PrevImageSource.Name, Mode=OneWay}">
          <Border Background="{ThemeResource SystemChromeMediumColor}"
                  CornerRadius="0 6 6 0">
            <Button HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind _vm.OpenMovieFileCommand}"
                    CommandParameter="{x:Bind _vm.PrevImageSource, Mode=OneWay}"
                    CornerRadius="0 6 6 0">
              <fluentIcon:FluentSymbolIcon Symbol="ArrowLeft24" />
            </Button>
          </Border>
        </StackPanel>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
