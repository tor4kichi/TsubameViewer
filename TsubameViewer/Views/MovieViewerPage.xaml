                             Grid.Column="0"
                             TextWrapping="Wrap"
                             MaxWidth="320"
                             VerticalAlignment="Center"/>

                  <Border Background="{ThemeResource SystemBaseLowColor}"
                          Height="1"
                          Grid.Column="1"
                          Margin="8" />

                  <TextBlock Text="{x:Bind ToText(Key, Modifier)}"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Grid.Column="2" />
