<Page
    x:Class="TsubameViewer.Views.MovieViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TsubameViewer.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:i="using:Microsoft.Xaml.Interactivity"
      xmlns:core="using:Microsoft.Xaml.Interactions.Core"
      xmlns:myConv="using:TsubameViewer.Views.Converters"
      xmlns:wst="using:Microsoft.Toolkit.Uwp.UI.Triggers"
      xmlns:uwpControls="using:Microsoft.Toolkit.Uwp.UI.Controls"
      xmlns:myBehaviour="using:TsubameViewer.Views.Behaviors"
      xmlns:uwpUIExtensions="using:Microsoft.Toolkit.Uwp.UI"
      xmlns:uiNavigation="using:TsubameViewer.Views.UINavigation"
      xmlns:domainModels="using:TsubameViewer.Core.Models"
      xmlns:myStateTriggers="using:TsubameViewer.Views.StateTrigger"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      xmlns:i18nExt="using:I18NPortable.Xaml.Extensions"
      xmlns:models="using:TsubameViewer.Core.Models.FolderItemListing"
      xmlns:vm="using:TsubameViewer.ViewModels"
      xmlns:animation="using:Microsoft.Toolkit.Uwp.UI.Animations"
      xmlns:fluentIcon="using:Fluent.Icons"
      mc:Ignorable="d"
    >

  <Page.Resources>
    <Style TargetType="fluentIcon:FluentSymbolIcon">
      <Setter Property="IsTabStop"
              Value="False" />
    </Style>

    <DataTemplate x:Name="TitlebarContent"
                  x:DataType="vm:MovieViewerPageViewModel">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal"
                    Grid.Column="1"
                    Spacing="8">
          <TextBlock x:Name="IfAllFilesWannaWatchThenRegistrationFolderAtApp_Desktop"
                     Text="{i18nExt:Localize Key=IfAllFilesWannaWatchThenRegistrationFolderAtApp}"
                     Foreground="{ThemeResource SystemErrorTextColor}"
                     Opacity="0"
                     Style="{StaticResource TitlebarTextBlock}" />
          <!--変形モード-->
          <!--
          <Button AccessKey="R"
                  Command="{x:Bind ToggleTransformModeCommand}">
            <SymbolIcon Symbol="ZoomIn" />
          </Button>
          -->
          <!-- 左右反転 -->
          <ToggleButton x:Name="FlipHorizontalButton"
                  AccessKey="Y"
                        IsChecked="{x:Bind PageSettings.IsHorizontalMirror, Mode=TwoWay}">
            <SymbolIcon Symbol="Sort"
                        RenderTransformOrigin="0.5, 0.5">
              <SymbolIcon.RenderTransform>
                <RotateTransform Angle="90" />
              </SymbolIcon.RenderTransform>
            </SymbolIcon>
          </ToggleButton>
          <Button Command="{x:Bind ToggleFullScreenCommand}"
                  Style="{StaticResource TitlebarButton}">
            <SymbolIcon Symbol="FullScreen"
                        Style="{StaticResource TitlebarSymbolIcon}">
            </SymbolIcon>
          </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
          <TextBlock Style="{StaticResource TitlebarTextBlock}">
            <Run Text="{x:Bind Title, Mode=OneWay}" />
          </TextBlock>
        </StackPanel>
      </Grid>
    </DataTemplate>

    <!--
    <XamlUICommand x:Key="ZoomResetUICommand"
                   Command="{x:Bind ZoomResetCommand}"
                   Label="{i18nExt:Localize Key=ZoomReset}"
                   Description="{i18nExt:Localize Key=ZoomReset}">
      <XamlUICommand.IconSource>
        <SymbolIconSource Symbol="ZoomIn" />
      </XamlUICommand.IconSource>
      <XamlUICommand.KeyboardAccelerators>
        <KeyboardAccelerator Key="X" />
        <KeyboardAccelerator Key="R" />
      </XamlUICommand.KeyboardAccelerators>
    </XamlUICommand>

    <XamlUICommand x:Key="ZoomInUICommand"
                   Command="{x:Bind ZoomUpWithControllerCommand}"
                   Label="{i18nExt:Localize Key=ZoomIn}"
                   Description="{i18nExt:Localize Key=ZoomIn}">
      <XamlUICommand.IconSource>
        <SymbolIconSource Symbol="ZoomIn" />
      </XamlUICommand.IconSource>
      <XamlUICommand.KeyboardAccelerators>
        <KeyboardAccelerator Key="Add" />
        <KeyboardAccelerator Key="W" />
        <KeyboardAccelerator Key="T" />
      </XamlUICommand.KeyboardAccelerators>
    </XamlUICommand>

    <XamlUICommand x:Key="ZoomOutUICommand"
                   Command="{x:Bind ZoomDownWithControllerCommand}"
                   Label="{i18nExt:Localize Key=ZoomOut}"
                   Description="{i18nExt:Localize Key=ZoomOut}">
      <XamlUICommand.IconSource>
        <SymbolIconSource Symbol="ZoomOut" />
      </XamlUICommand.IconSource>
      <XamlUICommand.KeyboardAccelerators>
        <KeyboardAccelerator Key="Subtract" />
        <KeyboardAccelerator Key="S" />
        <KeyboardAccelerator Key="Y" />
      </XamlUICommand.KeyboardAccelerators>
    </XamlUICommand>-->

    <local:SecondsToVideoTimeConverter x:Key="SecondsToVideoTimeConverter" />
    <local:ToPlaybackRateConverter x:Key="ToPlaybackRateConverter" />
  </Page.Resources>
  <Grid>

    <VisualStateManager.VisualStateGroups>

      <!-- 変形モードのUI表示状態 -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind _vm.IsTransformModeEnabled, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="TransformUIContainer.Visibility"
                    Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind IsDisplayControlUI, Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="TransformUIContainer.Visibility"
                    Value="Visible" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind IsDisplayControlUI, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="TransformUIContainer.Visibility"
                    Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
      
      <!-- プレイヤーコントロールUIの表示状態 -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind _vm.IsTransformModeEnabled, Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="ImageSelectorContainer.Opacity"
                    Value="0" />
            <Setter Target="ImageSelectorContainer.IsHitTestVisible"
                    Value="False" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind IsDisplayControlUI, Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="ImageSelectorContainer.Opacity"
                    Value="1" />
            <Setter Target="ImageSelectorContainer.IsHitTestVisible"
                    Value="True" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind IsDisplayControlUI, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="ImageSelectorContainer.Opacity"
                    Value="0" />
            <Setter Target="ImageSelectorContainer.IsHitTestVisible"
                    Value="False" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind IsMute, Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="ToggleIsMutedButton.Content">
              <Setter.Value>
                <fluentIcon:FluentSymbolIcon Symbol="SpeakerMute24" />
              </Setter.Value>
            </Setter>
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <wst:IsEqualStateTrigger Value="{x:Bind SoundVolume_Display, Mode=OneWay}"
                                     To="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="ToggleIsMutedButton.Content">
              <Setter.Value>
                <fluentIcon:FluentSymbolIcon Symbol="SpeakerMute24" />
              </Setter.Value>
            </Setter>
          </VisualState.Setters>
        </VisualState>

      </VisualStateGroup>

      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind TrueToPlayerPlaying(PlayerState), Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="ControlUI_PlayPauseButton.Content">
              <Setter.Value>
                <SymbolIcon Symbol="Pause" />
              </Setter.Value>
            </Setter>
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind _vm.PageSettings.IsHorizontalMirror, Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="MirrorScaleTransform.ScaleX"
                    Value="-1" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
      <!-- 全画面表示 -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind IsDisplayControlUI, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
          </VisualState.StateTriggers>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind NowFullScreenMode, Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FullScreenExitButtonContainer.Opacity"
                    Value="1" />
            <Setter Target="FullScreenExitButtonContainer.IsHitTestVisible"
                    Value="True" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>

    </VisualStateManager.VisualStateGroups>

    <MediaPlayerElement AutoPlay="False"
                        Stretch="Uniform"
                        x:Name="MyMediaPlayerElement"
                        RenderTransformOrigin="0.5, 0.5">
      <UIElement.RenderTransform>
        <TransformGroup>
          <TranslateTransform x:Name="PlayerTransform" />

          <ScaleTransform x:Name="MirrorScaleTransform" />
        </TransformGroup>
      </UIElement.RenderTransform>
    </MediaPlayerElement>

    <Grid IsHitTestVisible="True"
          Background="Transparent"
                  Opacity="0"
          PointerPressed="ControlUIInteractionWall_PointerPressed"
          PointerReleased="ControlUIInteractionWall_PointerReleased"
          x:Name="ControlUIInteractionWall"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
      
    </Grid>

    <Border x:Name="ImageSelectorContainer"
            Grid.ColumnSpan="3"
            VerticalAlignment="Bottom"
            Margin="0 0 0 16"
            Padding="0 8"
            Opacity="0"
            IsHitTestVisible="False"
            Background="{ThemeResource SystemAltMediumHighColor}"
            >
      <StackPanel Margin="8 0"
                  Spacing="6"
                  MaxWidth="720"
                  >

        <Grid Margin="0 0 0 8">
          <Grid.Resources>
            <ScaleTransform x:Key="FavoriteIconTransform"
                            ScaleX="0.9"
                            ScaleY="0.9" />
          </Grid.Resources>
          <Grid.ColumnDefinitions>
            <ColumnDefinition />
          </Grid.ColumnDefinitions>

          <muxc:DropDownButton x:Name="Page2ActionButton"
                               Grid.Column="0"
                               HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Stretch"
                               Margin="0 0 0 0"
                               IsAccessKeyScope="True"
                               AccessKey="2">
            <muxc:DropDownButton.KeyboardAccelerators>
              <KeyboardAccelerator Key="Number1" />
            </muxc:DropDownButton.KeyboardAccelerators>

            <uwpControls:DockPanel>
              <SymbolIcon Symbol="Favorite"
                          
                          uwpControls:DockPanel.Dock="Left"
                          Margin="0 0 4 0"
                          RenderTransform="{StaticResource FavoriteIconTransform}"
                          RenderTransformOrigin="0.5, 0.5" />
              <TextBlock x:Name="Page2NameTextBlock"
                         VerticalAlignment="Center"
                         FontSize="12"
                         Margin="0 0 0 0"
                         HorizontalAlignment="Center"
                         TextWrapping="Wrap"
                         MaxLines="1"
                         TextTrimming="CharacterEllipsis">
          <Run Text="{x:Bind _vm.Title, Mode=OneWay}" />
              </TextBlock>
            </uwpControls:DockPanel>

            <muxc:DropDownButton.Flyout>
              <MenuFlyout Opening="Page2MenuFlyout_Opening">
                <MenuFlyoutSubItem x:Name="Page2AlbamAddItemButton"
                                   Text="{i18nExt:Localize Key=AlbamItemAdd}"
                                   >

                </MenuFlyoutSubItem>
                <MenuFlyoutItem x:Name="Page2SetThubmailImageButton"
                                AccessKey="T"
                                Text="{i18nExt:Localize Key=SetThumbnailImage}"
                                >
                  <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Key="T" />
                  </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator x:Name="Page2ThumbnailImageSeparator" />
                <MenuFlyoutItem x:Name="Page2OpenWithExplorerButton"
                                AccessKey="G"
                                Text="{i18nExt:Localize Key=OpenWithExplorer}"
                                >
                  <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Key="G" />
                  </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="Page2OpenWithExternalAppButton"
                                AccessKey="B"
                                Text="{i18nExt:Localize Key=OpenWithExternalApplication}"
                                >
                  <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Key="B" />
                  </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
              </MenuFlyout>
            </muxc:DropDownButton.Flyout>
          </muxc:DropDownButton>
        </Grid>

        <uwpControls:DockPanel>
          <StackPanel Orientation="Horizontal"
                      uwpControls:DockPanel.Dock="Right"
                      Spacing="8">
            <Button Content="{x:Bind ToPlaybackRateString(_vm.PageSettings.PlaybackRate), Mode=OneWay}"
                    MinWidth="60">
              <Button.Flyout>
                <Flyout>
                  <StackPanel>
                    <StackPanel.Resources>
                      <Style TargetType="Button">
                        <Setter Property="Padding"
                                Value="8 4" />
                        <Setter Property="CornerRadius"
                                Value="4" />
                        <Setter Property="MinWidth"
                                Value="52" />
                      </Style>
                    </StackPanel.Resources>
                    <StackPanel Orientation="Horizontal"
                                Spacing="4">
                      <Button Content="x0.5"
                              Command="{x:Bind SetPlaybackRateCommand}">
                        <Button.CommandParameter>
                          <x:Double>0.5</x:Double>
                        </Button.CommandParameter>
                      </Button>
                      <Button Content="x0.75"
                              Command="{x:Bind SetPlaybackRateCommand}">
                        <Button.CommandParameter>
                          <x:Double>0.75</x:Double>
                        </Button.CommandParameter>
                      </Button>
                      <Button Content="x1.0"
                              Command="{x:Bind SetPlaybackRateCommand}">
                        <Button.CommandParameter>
                          <x:Double>1.0</x:Double>
                        </Button.CommandParameter>
                      </Button>
                      <Button Content="x1.25"
                              Command="{x:Bind SetPlaybackRateCommand}">
                        <Button.CommandParameter>
                          <x:Double>1.25</x:Double>
                        </Button.CommandParameter>
                      </Button>
                      <Button Content="x1.5"
                              Command="{x:Bind SetPlaybackRateCommand}">
                        <Button.CommandParameter>
                          <x:Double>1.5</x:Double>
                        </Button.CommandParameter>
                      </Button>
                      <Button Content="x1.75"
                              Command="{x:Bind SetPlaybackRateCommand}">
                        <Button.CommandParameter>
                          <x:Double>1.75</x:Double>
                        </Button.CommandParameter>
                      </Button>
                      <Button Content="x2.0"
                              Command="{x:Bind SetPlaybackRateCommand}">
                        <Button.CommandParameter>
                          <x:Double>2.0</x:Double>
                        </Button.CommandParameter>
                      </Button>
                    </StackPanel>

                    <Slider HorizontalAlignment="Stretch"
                            Maximum="{x:Bind MaxPlaybackRate}"
                            Minimum="{x:Bind MinPlaybackRate}"
                            Value="{x:Bind _vm.PageSettings.PlaybackRate, Mode=OneWay}"
                            ValueChanged="PlaybackRateSlider_ValueChanged"
                            StepFrequency="0.1"
                            x:Name="PlaybackRateSlider"
                            IsThumbToolTipEnabled="True"
                            ThumbToolTipValueConverter="{StaticResource ToPlaybackRateConverter}" />
                    <Grid>
                      <TextBlock Text="x0.1"
                                 HorizontalAlignment="Left" />
                      <TextBlock Text="x1.0"
                                 HorizontalAlignment="Center"
                                 Margin="0 0 198 0" />
                      <TextBlock Text="x2.0"
                                 HorizontalAlignment="Center"
                                 Margin="0 0 12 0" />
                      <TextBlock Text="x3.0"
                                 HorizontalAlignment="Center"
                                 Margin="180 0 0 0" />
                      <TextBlock Text="x4.0"
                                 HorizontalAlignment="Right" />
                    </Grid>
                  </StackPanel>
                </Flyout>
              </Button.Flyout>
            </Button>
            <ToggleButton x:Name="ControlUI_RepeatButton"
                          IsChecked="{x:Bind _vm.PageSettings.IsRepeat, Mode=TwoWay}"
                          Height="40"
                          Width="48">
              <SymbolIcon Symbol="RepeatAll" />
            </ToggleButton>
          </StackPanel>
          <StackPanel Orientation="Horizontal"
                      uwpControls:DockPanel.Dock="Left">
            <Button x:Name="ControlUI_PlayPauseButton"
                    Command="{x:Bind TogglePlayPauseCommand}"
                    Height="40"
                    Width="48">
              <SymbolIcon Symbol="Play" />
            </Button>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <Button x:Name="ToggleIsMutedButton"
                    Command="{x:Bind ToggleIsMutedCommand}"
                    Height="40"
                    Width="48">
              <fluentIcon:FluentSymbolIcon Symbol="Speaker224" />
            </Button>
            <Slider Value="{x:Bind SoundVolume_Display, Mode=OneWay}"
                    Maximum="1"
                    Minimum="0"
                    StepFrequency="0.01"
                    x:Name="ControlUI_SoundVolumeSlider"                    
                    MinWidth="120"
                    Margin="0 4 0 0"
                    ThumbToolTipValueConverter="{StaticResource DoubleToPercentTextConverter}">

            </Slider>
          </StackPanel>
        </uwpControls:DockPanel>
        <!-- ComboBox に対するフォーカス移動が意図どおり出来ないので
         XYFocus*を使って強制的に移動先を指定している 
    -->
        <!--
        <ComboBox x:Name="PageFolderNamesSelector"
                  uwpControls:DockPanel.Dock="Top"
                  ItemsSource="{Binding PageFolderNames}"
                  SelectedItem="{Binding PageFolderName, Mode=TwoWay}"
                  SelectionChangedTrigger="Committed"
                  ToolTipService.ToolTip="{i18nExt:Localize Key=CurrentFolder_InArchive}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Margin="0 4"
                  AccessKey="3">
          <i:Interaction.Behaviors>
            <core:EventTriggerBehavior EventName="SelectionChanged">
              <core:InvokeCommandAction Command="{Binding ChangePageFolderCommand}">
                <core:InvokeCommandAction.InputConverter>
                  <local:SelectorSelectedChangedToStringConverter />
                </core:InvokeCommandAction.InputConverter>
              </core:InvokeCommandAction>
              <core:CallMethodAction TargetObject="{Binding ElementName=PageFlyout}"
                                     MethodName="Hide" />
            </core:EventTriggerBehavior>
          </i:Interaction.Behaviors>

          <ComboBox.KeyboardAccelerators>
            <KeyboardAccelerator Key="3" />
          </ComboBox.KeyboardAccelerators>
        </ComboBox>
-->
        <Grid>
          <Slider x:Name="PageSelector"
                  uwpControls:DockPanel.Dock="Bottom"
                  Minimum="0"
                  Maximum="{x:Bind ToTotalSeconds(VideoDuration), Mode=OneWay}"
                  Value="{x:Bind ToTotalSeconds(VideoPosition), Mode=OneWay}"
                  ValueChanged="VideoPositionSlider_ValueChanged"
                  ThumbToolTipValueConverter="{StaticResource SecondsToVideoTimeConverter}"
                  TickFrequency="0.01"
                  StepFrequency="0.01"
                  Padding="0"
                  Margin="0 0"
                  FlowDirection="LeftToRight"
                  AccessKey="4">
            <Slider.KeyboardAccelerators>
              <KeyboardAccelerator Key="4" />
            </Slider.KeyboardAccelerators>
          </Slider>
          <TextBlock VerticalAlignment="Bottom"
                     FontSize="12"
                     Margin="0 32 8 0"                     
                     HorizontalAlignment="Right"
                     uwpControls:DockPanel.Dock="Bottom">

            <TextBlock.RenderTransform>
              <TranslateTransform Y="-6" />
            </TextBlock.RenderTransform>

<Run Text="{x:Bind VideoPosition, Mode=OneWay, Converter={StaticResource TimeSpanToSimpleTextConverter}}" />/<Run Text="{x:Bind VideoDuration, Mode=OneWay, Converter={StaticResource TimeSpanToSimpleTextConverter}}" />
          </TextBlock>
        </Grid>
      </StackPanel>

    </Border>

    <Border x:Name="TransformUIContainer"
            Background="{ThemeResource SystemChromeMediumHighColor}"
            Grid.ColumnSpan="3"
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
            Width="460"
            CornerRadius="8"
            Margin="0 0 0 16"
            Translation="0, 0, 16">
      <Border.Shadow>
        <ThemeShadow />
      </Border.Shadow>
      <!--<animation:Implicit.ShowAnimations>
        <animation:TranslationAnimation To="0, 0"
                                        EasingType="Cubic"
                                        Duration="0:0:0.175" />
      </animation:Implicit.ShowAnimations>
      <animation:Implicit.HideAnimations>
        <animation:TranslationAnimation To="0, 180"
                                        EasingType="Cubic"
                                        Duration="0:0:0.175" />
      </animation:Implicit.HideAnimations>-->

      <StackPanel Margin="8"
                  Spacing="6"
                  Orientation="Horizontal">
        <Button x:Name="TransformUI_PlayPauseButton"
                Command="{x:Bind TogglePlayPauseCommand}">
          <SymbolIcon Symbol="Play" />
        </Button>
      </StackPanel>
    </Border>

    <Grid HorizontalAlignment="Center"
          VerticalAlignment="Top"
          Opacity="0"
          IsHitTestVisible="False"
          x:Name="FullScreenExitButtonContainer"
          Background="{ThemeResource ApplicationContentBackgroundBrush}"
          CornerRadius="24"
          BorderBrush="{ThemeResource SystemBaseMediumColor}"
          BorderThickness="1"
          Margin="48">
      <Button Command="{x:Bind _vm.ToggleFullScreenCommand}"
              Width="60"
              Height="60"
              RenderTransformOrigin="0.5, 0.5"
              FontWeight="Thin"
              Padding="1 1 0 0">
        <UIElement.RenderTransform>
          <ScaleTransform ScaleX="1.5"
                          ScaleY="1.5" />
        </UIElement.RenderTransform>
        <SymbolIcon Symbol="Clear" />
      </Button>
    </Grid>
    <ProgressBar Minimum="0"
                      Maximum="{x:Bind ToTotalSeconds(VideoDuration), Mode=OneWay}"
                      Value="{x:Bind ToTotalSeconds(VideoPosition), Mode=OneWay}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Bottom"
                      IsHitTestVisible="False"
                      Opacity="0.3"           
                 Visibility="{x:Bind IsDisplayControlUI, Mode=OneWay, Converter={StaticResource FalseToVisibleConverter}}"
                      />

    <muxc:ProgressBar IsIndeterminate="True"
                  Opacity="1"
                      Visibility="{x:Bind IsPalyerPreparing(PlayerState), Mode=OneWay}"
                  IsHitTestVisible="False"
                  Foreground="{ThemeResource SystemAccentColor}"
                  x:Name="LoadingProgressRing"
                  VerticalAlignment="Bottom"
                      HorizontalAlignment="Stretch"
                  />
  </Grid>
</Page>
