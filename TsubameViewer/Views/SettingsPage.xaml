<Page x:Class="TsubameViewer.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:TsubameViewer.Views"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:uwpControls="using:Microsoft.Toolkit.Uwp.UI.Controls"
      xmlns:tt="using:TsubameViewer.Views.TemplateSelector"
      xmlns:wst="using:WindowsStateTriggers"
      xmlns:vm="using:TsubameViewer.ViewModels"
      xmlns:i18Ext="using:I18NPortable.Xaml.Extensions"
      xmlns:winui="using:Microsoft.UI.Xaml.Controls"
      xmlns:sss="using:Windows.Globalization.NumberFormatting"
      xmlns:winUIControls="using:CommunityToolkit.WinUI.Controls"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationContentBackgroundBrush}">
  <Page.Resources>
    <DataTemplate x:Name="TitlebarContent"
                  x:DataType="vm:SettingsPageViewModel">
      <StackPanel Orientation="Horizontal"
                  Spacing="8"                   
                  HorizontalAlignment="Right">

      </StackPanel>
    </DataTemplate>
    
    <x:Double x:Key="SettingItemWidth">400</x:Double>
    <x:Double x:Key="GroupSpacing">48</x:Double>
    <x:Double x:Key="ItemsSpacing">24</x:Double>

    <Style TargetType="ToggleSwitch" BasedOn="{StaticResource ToggleSwitchNoHeader}" />

    <tt:SettingsItemTemplateSelector x:Key="SettingItemTemplateSelector">
      <tt:SettingsItemTemplateSelector.ToggleSwitchSettingItem>
        <DataTemplate x:DataType="vm:IToggleSwitchSettingItemViewModel">
          <winUIControls:SettingsCard Header="{x:Bind Label}"
                                      Description="{x:Bind Desc}"
                                      Visibility="{Binding IsVisible, Converter={StaticResource TrueToVisibleConverter}}">
            <ToggleSwitch IsOn="{x:Bind ValueContainer.Value, Mode=TwoWay}"
                          uwpControls:DockPanel.Dock="Right"
                          Margin="0"
                          Padding="0" />
          </winUIControls:SettingsCard>
        </DataTemplate>
      </tt:SettingsItemTemplateSelector.ToggleSwitchSettingItem>

      <tt:SettingsItemTemplateSelector.SelectorSettingItem>
        <DataTemplate x:DataType="vm:ISelectorSettingsItemViewModel">
          <winUIControls:SettingsCard Header="{x:Bind Label}"
                                      Description="{x:Bind Desc}">
            <!--<winUIControls:Segmented ItemsSource="{x:Bind Items}"
                                     SelectedItem="{x:Bind SelectedItem, Mode=OneWay}"
                                     ItemTemplate="{StaticResource LocalizeTextTemplate}"
                                     SelectionChanged="Segmented_SelectionChanged" />-->

            <ListView ItemsSource="{x:Bind Items}"
                      SelectedItem="{x:Bind SelectedItem, Mode=OneWay}"
                      ItemTemplate="{StaticResource LocalizeTextTemplate}"
                      SelectionChanged="Segmented_SelectionChanged" />
          </winUIControls:SettingsCard>
        </DataTemplate>
      </tt:SettingsItemTemplateSelector.SelectorSettingItem>

      <!-- アプリに記録されたフォルダ -->
      <tt:SettingsItemTemplateSelector.StoredFoldersSettingItem>
        <DataTemplate x:DataType="vm:StoredFoldersSettingItemViewModel">
          <StackPanel>
            <winUIControls:SettingsExpander ItemsSource="{x:Bind Folders}"
                                            Header="{i18Ext:Localize Key=Folders}">
              <winUIControls:SettingsExpander.ItemTemplate>
                <DataTemplate x:DataType="vm:StoredFolderViewModel">
                  <winUIControls:SettingsCard Header="{x:Bind FolderName}"
                                              Description="{x:Bind Path}">
                    <Button Content="{Binding Source=RemoveSourceFolderFromApp, Converter={StaticResource LocalizeConverter}}"
                            Command="{x:Bind DeleteStoredFolderCommand}" />
                  </winUIControls:SettingsCard>
                </DataTemplate>
              </winUIControls:SettingsExpander.ItemTemplate>
            </winUIControls:SettingsExpander>
            <winUIControls:SettingsExpander ItemsSource="{x:Bind TempFiles}"
                                            Header="{i18Ext:Localize Key=RecentlyUsedFiles}">
              <winUIControls:SettingsExpander.ItemTemplate>
                <DataTemplate x:DataType="vm:StoredFolderViewModel">
                  <winUIControls:SettingsCard Header="{x:Bind FolderName}"
                                              Description="{x:Bind Path}">
                    <Button Content="{Binding Source=RemoveSourceFolderFromApp, Converter={StaticResource LocalizeConverter}}"
                            Command="{x:Bind DeleteStoredFolderCommand}" />
                  </winUIControls:SettingsCard>
                </DataTemplate>
              </winUIControls:SettingsExpander.ItemTemplate>
            </winUIControls:SettingsExpander>
          </StackPanel>
        </DataTemplate>

      </tt:SettingsItemTemplateSelector.StoredFoldersSettingItem>

      <tt:SettingsItemTemplateSelector.UpdatableTextSettingItem>
        <DataTemplate x:DataType="vm:UpdatableTextSettingItemViewModel">
          <winUIControls:SettingsCard Visibility="{x:Bind IsVisible, Converter={StaticResource TrueToVisibleConverter}}"
                                      Header="{x:Bind Label}"
                                      Description="{x:Bind Text.Value, Mode=OneWay}" />
        </DataTemplate>
      </tt:SettingsItemTemplateSelector.UpdatableTextSettingItem>
      <tt:SettingsItemTemplateSelector.ButtonSettingItem>
        <DataTemplate x:DataType="vm:ButtonSettingItemViewModel">
          <winUIControls:SettingsCard Header="{x:Bind Label, Mode=OneWay}"
                                      Description="{x:Bind Description, Mode=OneWay}">
            <Button Content="{x:Bind ButtonLabel, Mode=OneWay}"
                    Command="{x:Bind ActionCommand}"
                    MaxWidth="{StaticResource SettingItemWidth}"
                    HorizontalAlignment="Right"
                    Visibility="{x:Bind IsVisible, Converter={StaticResource TrueToVisibleConverter}}"
                    Margin="0 16" />
          </winUIControls:SettingsCard>
        </DataTemplate>
      </tt:SettingsItemTemplateSelector.ButtonSettingItem>
      <tt:SettingsItemTemplateSelector.ThemeSelectSettingItem>
        <DataTemplate x:DataType="vm:ThemeSelectSettingItemViewModel">
          <winUIControls:SettingsCard Header="{x:Bind Label}">
            <ComboBox ItemsSource="{x:Bind ThemeItems}"
                      SelectedItem="{x:Bind SelectedTheme.Value, Mode=TwoWay}"
                      HorizontalAlignment="Right">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={StaticResource LocalizeConverter}}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

          </winUIControls:SettingsCard>
        </DataTemplate>
      </tt:SettingsItemTemplateSelector.ThemeSelectSettingItem>
      <tt:SettingsItemTemplateSelector.LocaleSelectSettingItem>
        <DataTemplate x:DataType="vm:LocaleSelectSettingItemViewModel">
          <winUIControls:SettingsCard Header="{x:Bind Label}">
            <StackPanel>
              <ComboBox ItemsSource="{x:Bind Locales}"
                        SelectedValue="{x:Bind SelectedLocale, Mode=OneWay}"
                        SelectionChanged="ComboBox_SelectionChanged"                        
                        HorizontalAlignment="Right">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock>
                      <Run Text="{Binding DisplayName}" /> <Run Text="{Binding Locale}" />
                    </TextBlock>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <Button Content="{x:Bind RestartTextTranslated}"
                      Command="{x:Bind RestartApplicationCommand}"
                      Visibility="{x:Bind IsRequireRestart, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}"
                      Margin="0 16 0 0"/>
            </StackPanel>
          </winUIControls:SettingsCard>
        </DataTemplate>
      </tt:SettingsItemTemplateSelector.LocaleSelectSettingItem>
      <tt:SettingsItemTemplateSelector.NumericTextBoxSettingItem>
        <DataTemplate x:DataType="vm:NumberBoxSettingItemViewModel">
          <winUIControls:SettingsCard Header="{x:Bind Label}"
                                      Description="{x:Bind Desc}">
            <Slider Value="{x:Bind FirstValue}"
                    ValueChanged="{x:Bind OnValueChanged}"
                    Minimum="{x:Bind MinValue}"
                    Maximum="{x:Bind MaxValue}"           
                    StepFrequency="{x:Bind ValueStep}"
                    TickFrequency="{x:Bind ValueStep}"
                    HorizontalAlignment="Right"
                    HorizontalContentAlignment="Right"
                    MinWidth="240"
                    ThumbToolTipValueConverter="{StaticResource DoubleToPercentTextConverter}"
                    Header="{Binding RelativeSource={RelativeSource Mode=Self}, Path=Value, Converter={StaticResource DoubleToPercentTextConverter}}">
            </Slider>
          </winUIControls:SettingsCard>
        </DataTemplate>
      </tt:SettingsItemTemplateSelector.NumericTextBoxSettingItem>
    </tt:SettingsItemTemplateSelector>

    <DataTemplate x:Key="SettingsGroupTemplate"
                  x:DataType="vm:SettingsGroupViewModel">
      <StackPanel Spacing="8" >
        <TextBlock Text="{x:Bind  Label}" Style="{StaticResource SubtitleTextBlockStyle}" />
        <ItemsControl ItemsSource="{x:Bind  Items}"
                      ItemTemplateSelector="{StaticResource SettingItemTemplateSelector}"
                      HorizontalAlignment="Stretch"                      
                      IsTabStop="False"
                        >
        </ItemsControl>
      </StackPanel>
    </DataTemplate>
    
  </Page.Resources>
  <Grid>
    <uwpControls:DockPanel>

      <Grid MaxWidth="600"
            uwpControls:DockPanel.Dock="Top"
            Padding="0 32 0 0">
        <Border Height="1"
                VerticalAlignment="Bottom"
                Background="{ThemeResource SystemBaseLowColor}" 
                Opacity="0.3"/>
        <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
          <Button Command="{x:Bind BackNavigationRequestCommand}"
                  HorizontalAlignment="Left">
            <SymbolIcon Symbol="Back" />
          </Button>

          <TextBlock Text="{i18Ext:Localize Key=Settings}" 
                     VerticalAlignment="Center"
                     TextLineBounds="TrimToCapHeight"
                     Style="{StaticResource TitleTextBlockStyle}"
                     Margin="16 0 0 0"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0 0 0 8">
          <StackPanel Orientation="Horizontal"
                      Spacing="8"
                      HorizontalAlignment="Right">
            <Button ToolTipService.ToolTip="{i18Ext:Localize Key=CopyToClipboard}"
                    Command="{x:Bind _vm.AppInfoCopyToClipboard}"
                    Style="{StaticResource TitlebarButton}">
              <SymbolIcon Symbol="Copy" />
            </Button>
            <TextBlock Text="{x:Bind _vm.ReportUserEnvString}"
                       IsTextSelectionEnabled="True"
                       HorizontalAlignment="Right"
                       TextAlignment="Right"
                       Opacity="0.7">
              <TextBlock.ContextFlyout>
                <MenuFlyout>
                  <MenuFlyoutItem Text="{i18Ext:Localize Key=CopyToClipboard}"
                                  Command="{x:Bind _vm.AppInfoCopyToClipboard}" />
                </MenuFlyout>
              </TextBlock.ContextFlyout>
            </TextBlock>

          </StackPanel>
        </StackPanel>
      </Grid>
      
      <ScrollViewer>
        <StackPanel x:Name="ScrollViewerRootPanel" Padding="0 0 0 64">
          <ItemsControl ItemsSource="{x:Bind _vm.SettingGroups, Mode=OneWay}"
                        ItemTemplate="{StaticResource SettingsGroupTemplate}"
                      Margin="32 16"
                        IsTabStop="False"
                        HorizontalAlignment="Stretch"
                        MaxWidth="600"                        
                      >
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Spacing="16" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>

          <StackPanel Spacing="0"
                      HorizontalAlignment="Center"
                      Margin="0 16 0 16"
                      >
            <HyperlinkButton Content="{Binding Source=PrivacyPolicy, Converter={StaticResource LocalizeConverter}}" 
                             NavigateUri="https://github.com/tor4kichi/TsubameViewer/wiki/Privacy-Policy" 
                             HorizontalContentAlignment="Right"
                             FontWeight="SemiBold"
                             Width="600"
                             />
            <HyperlinkButton Content="{Binding Source=ThirdPartyLibraryNotice, Converter={StaticResource LocalizeConverter}}" 
                             NavigateUri="https://github.com/tor4kichi/TsubameViewer/wiki/Third-Party-Library-Notice" 
                             HorizontalContentAlignment="Right"
                             FontWeight="SemiBold"
                             Width="600"
                             />

            <HyperlinkButton Content="{Binding Source=AskQuestionWithMashmarrow, Converter={StaticResource LocalizeConverter}}" 
                             NavigateUri="https://marshmallow-qa.com/tor4kichi" 
                             HorizontalContentAlignment="Right"
                             FontWeight="SemiBold"
                             Width="600"
                             />
          </StackPanel>
          

          <!-- AdvancedSetting -->
          <!--<uwpControls:Expander Margin="32 64 32 32" Visibility="Collapsed">
            <uwpControls:Expander.Header>
              <TextBlock Text="{Binding Source=AdvancedSettings, Converter={StaticResource LocalizeConverter}}"
                     Style="{StaticResource SubtitleTextBlockStyle}"
                     />
            </uwpControls:Expander.Header>

            <ItemsControl ItemsSource="{x:Bind _vm.AdvancedSettingGroups, Mode=OneWay}"
                        ItemTemplate="{StaticResource SettingsGroupTemplate}"
                      Margin="32 16"
                          HorizontalAlignment="Left"
                          IsTabStop="False"
                      >
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="{StaticResource GroupSpacing}" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </uwpControls:Expander>-->          
        </StackPanel>
        
        
      </ScrollViewer>
    </uwpControls:DockPanel>

    <VisualStateManager.VisualStateGroups>
      <!-- 画面サイズによる表示切り替え -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <wst:DeviceFamilyStateTrigger DeviceFamily="Xbox" />
            <StateTrigger IsActive="{StaticResource DebugTVMode}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="ScrollViewerRootPanel.Padding" Value="80 0 80 27" />
          </VisualState.Setters>
        </VisualState>

        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1220" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="610" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>
  </Grid>
</Page>
