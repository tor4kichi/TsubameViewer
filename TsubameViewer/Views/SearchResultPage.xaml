<Page
    x:Class="TsubameViewer.Views.SearchResultPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TsubameViewer.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
  xmlns:winUI="using:CommunityToolkit.WinUI"
  xmlns:ts="using:TsubameViewer.Views.TemplateSelector" 
  xmlns:myBehaior="using:TsubameViewer.Views.Behaviors" 
  xmlns:i="using:Microsoft.Xaml.Interactivity" 
  xmlns:wst="using:WindowsStateTriggers"
  xmlns:uwpUIExtensions="using:CommunityToolkit.WinUI"  
      xmlns:i18nExt="using:I18NPortable.Xaml.Extensions"
      xmlns:vm="using:TsubameViewer.ViewModels"
      xmlns:uiNavigation="using:TsubameViewer.Views.UINavigation"
      xmlns:uwpControls="using:CommunityToolkit.WinUI.Controls"
      xmlns:uwpControls1="using:CommunityToolkit.WinUI.Controls"
      mc:Ignorable="d"
    Background="{ThemeResource ApplicationContentBackgroundBrush}">

  <Page.Resources>
    <DataTemplate x:Name="TitlebarContent"
                  x:DataType="vm:SearchResultPageViewModel">
      <uwpControls:DockPanel>
        <StackPanel Orientation="Horizontal"
                    Grid.Column="1"
                    uwpControls:DockPanel.Dock="Right">

        </StackPanel>
        <StackPanel Orientation="Horizontal" uwpControls:DockPanel.Dock="Left">
        </StackPanel>

        <AutoSuggestBox PlaceholderText="{i18nExt:Localize Key=Search_FromAll}"
                        Text="{x:Bind FilterText, Mode=TwoWay}"
                        QueryIcon="Find"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        x:Name="AutoSuggestBox"
                        Padding="0"
                        Width="196"
                        TextMemberPath="Title"
                        UpdateTextOnSelect="False"
                        AutoMaximizeSuggestionArea="True"
                        IsSuggestionListOpen="True"
                        IsFocusEngagementEnabled="True"
                        UseSystemFocusVisuals="True"
                        TextChanged="AutoSuggestBox_TextChanged"
                        SuggestionChosen="AutoSuggestBox_SuggestionChosen"
                        Loaded="PrimaryWindowCoreLayout_Loaded"
                        Unloaded="AutoSuggestBox_Unloaded"
                        FocusVisualSecondaryBrush="{ThemeResource SystemAccentColor}"
                        AccessKey="F"
                        AccessKeyInvoked="AutoSuggestBox_AccessKeyInvoked"
                        QuerySubmitted="AutoSuggestBox_QuerySubmitted">
          <AutoSuggestBox.TextBoxStyle>
            <Style TargetType="TextBox">
              <Setter Property="IsSpellCheckEnabled"
                      Value="False" />
            </Style>
          </AutoSuggestBox.TextBoxStyle>
          <i:Interaction.Behaviors>
            <!--<i:EventTriggerBehavior EventName="QuerySubmitted">
      <i:InvokeCommandAction Command="{x:Bind _vm.SearchQuerySubmitCommand}" InputConverter="{StaticResource AutoSuggestBoxQuerySubmittedEventArgsConverter}" />
    </i:EventTriggerBehavior>-->
            <uiNavigation:UINavigationTriggerBehavior Kind="Cancel"
                                                      IsRequireFocus="True">
              <i:CallMethodAction TargetObject="{Binding ElementName=AutoSuggestBox}"
                                     MethodName="RemoveFocusEngagement" />
            </uiNavigation:UINavigationTriggerBehavior>
          </i:Interaction.Behaviors>

          <AutoSuggestBox.KeyboardAccelerators>
            <KeyboardAccelerator Key="F"
                                 Modifiers="Control"
                                 Invoked="KeyboardAccelerator_Invoked" />
          </AutoSuggestBox.KeyboardAccelerators>

          <AutoSuggestBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}"
                         FontSize="12"
                         TextWrapping="Wrap" />
            </DataTemplate>
          </AutoSuggestBox.ItemTemplate>
        </AutoSuggestBox>
      </uwpControls:DockPanel>
    </DataTemplate>

    <CollectionViewSource x:Key="SearchResultItemsViewSource"
                          ItemsPath="Items"
                          IsSourceGrouped="True"
                          Source="{x:Bind _vm.SearchResultItems}">
      
    </CollectionViewSource>
  </Page.Resources>

  <Grid Margin="0 0 0 0">
    <uwpControls:DockPanel>
      <StackPanel uwpControls:DockPanel.Dock="Top"
                  x:Name="HeaderLayout"
                  Background="{ThemeResource ApplicationContentBackgroundBrush}"
                  Padding="8 8 8 0"
                  Margin="0 24 0 0">
        <StackPanel Orientation="Horizontal"
                    Margin="8 0"
                    HorizontalAlignment="Right">
          <TextBlock Margin="0 0 0 0"
                     VerticalAlignment="Center">
            <Run Text="{x:Bind _vm.HitCount, Mode=OneWay, Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='Search_DisplayItemsCount'}" />
          </TextBlock>
        </StackPanel>
      </StackPanel>
      <uwpControls1:AdaptiveGridView ItemsSource="{Binding Source={StaticResource SearchResultItemsViewSource}}"
                                    x:Name="FoldersAdaptiveGridView"
                                    StretchContentForSingleRow="False"
                                    OneRowModeEnabled="False"
                                    VerticalAlignment="Top"
                                    ItemTemplateSelector="{StaticResource FolderItemTemplateSelector}"
                                    ItemContainerStyle="{StaticResource FolderStyle}"
                                    DesiredWidth="{StaticResource FolderGridViewItemWidth}"
                                    ItemHeight="160"
                                    IsItemClickEnabled="True"
                                    ItemClickCommand="{Binding OpenFolderItemCommand}"
                                    IsSynchronizedWithCurrentItem="False"
                                    SelectionMode="None"
                                    XYFocusDownNavigationStrategy="NavigationDirectionDistance"
                                    IsTabStop="False"
                                    ContextFlyout="{StaticResource RootPageStorageItemMenuFlyout}">
        <GridView.GroupStyle>
          <GroupStyle>
            <GroupStyle.HeaderTemplate>
              <DataTemplate x:DataType="vm:ItemsGroupedByFolderViewModel">
                <StackPanel>
                  <TextBlock Text="{Binding Name}" />
                </StackPanel>
              </DataTemplate>
            </GroupStyle.HeaderTemplate>
          </GroupStyle>
        </GridView.GroupStyle>
        <GridView.ItemContainerTransitions>
          <TransitionCollection />
        </GridView.ItemContainerTransitions>

      </uwpControls1:AdaptiveGridView>
    </uwpControls:DockPanel>

    <VisualStateManager.VisualStateGroups>
      <!-- 画面サイズによる表示切り替え -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <wst:DeviceFamilyStateTrigger DeviceFamily="Xbox" />
            <StateTrigger IsActive="{StaticResource DebugTVMode}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding" Value="48 0 48 27" />
            <Setter Target="HeaderLayout.Padding" Value="48 0" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1600" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding" Value="280 0 280 32" />
            <Setter Target="HeaderLayout.Padding" Value="280 0" />
          </VisualState.Setters>
        </VisualState>

        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1220" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding" Value="140 0 140 32" />
            <Setter Target="HeaderLayout.Padding" Value="140 0" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="610" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding" Value="48 0 48 32" />
            <Setter Target="HeaderLayout.Padding" Value="48 0" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding" Value="8 0 8 32" />
            <Setter Target="HeaderLayout.Padding" Value="8 0" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>
  </Grid>
  
</Page>
