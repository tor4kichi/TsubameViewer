<MenuFlyout
    x:Class="TsubameViewer.Views.Flyouts.StorageItemMenuFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TsubameViewer.Views.Flyouts"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:i18nExt="using:I18NPortable.Xaml.Extensions"
  Opened="FolderAndArchiveMenuFlyout_Opened"
    >

  
  
  <MenuFlyoutItem x:Name="OpenListupItem" Text="{i18nExt:Localize Key=OpenFolderListup}" />
  <MenuFlyoutItem x:Name="OpenViewerItem" Text="{i18nExt:Localize Key=OpenImageViewer}" />

  <ToggleMenuFlyoutItem x:Name="ToggleFavoriteMenuItem" />
  
  <MenuFlyoutSubItem x:Name="SendOtherFolderMenuItem"
                     Text="{i18nExt:Localize Key=SendToOtherFolder}" />
  <MenuFlyoutItem x:Name="SetThumbnailImageMenuItem"
                  Text="{i18nExt:Localize Key=SetThumbnailImage}" />

  <MenuFlyoutItem x:Name="ToggleReadingFinishedStateItem" />
  
  <MenuFlyoutSubItem x:Name="SelectItemsSubItem" Text="{i18nExt:Localize Key=SelectItems_ActionAs}">
    <MenuFlyoutItem x:Name="SelectedItems_AddFavariteImageMenuItem" />
    <MenuFlyoutItem x:Name="SelectedItems_OpenWithExplorerItem" Text="{i18nExt:Localize Key=OpenWithExplorer}" />
  </MenuFlyoutSubItem>

  <MenuFlyoutSeparator x:Name="FolderAndArchiveMenuSeparator2" />
  <MenuFlyoutItem x:Name="OpenWithExplorerItem"
                  Text="{i18nExt:Localize Key=OpenWithExplorer}" />
  <MenuFlyoutItem x:Name="OpenWithExternalAppMenuItem"
                  Text="{i18nExt:Localize Key=OpenWithExternalApplication}" />

  <MenuFlyoutItem x:Name="AddSecondaryTile" Text="{i18nExt:Localize Key=AddSecondaryTile}" />
  <MenuFlyoutItem x:Name="RemoveSecondaryTile" Text="{i18nExt:Localize Key=RemoveSecondaryTile}" />

  <MenuFlyoutSeparator x:Name="FileControlMenuSeparator" />
  <MenuFlyoutItem x:Name="StorageItemDeleteMenuItem"
                  Text="{i18nExt:Localize Key=Delete}" />

  <MenuFlyoutItem x:Name="RemoveFromAccessListMenuItem"
                  Text="{i18nExt:Localize Key=RemoveSourceFolderFromApp}" />
</MenuFlyout>
