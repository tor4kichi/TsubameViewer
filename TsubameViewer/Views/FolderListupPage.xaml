<Page
    x:Class="TsubameViewer.Views.FolderListupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TsubameViewer.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ts="using:TsubameViewer.Views.TemplateSelector" 
  xmlns:uwpControls="using:CommunityToolkit.WinUI.Controls" 
  xmlns:i="using:Microsoft.Xaml.Interactivity"   
  xmlns:myBehaior="using:TsubameViewer.Views.Behaviors" 
  xmlns:wst="using:WindowsStateTriggers" 
  xmlns:folderModels ="using:TsubameViewer.Core.Models.FolderItemListing" 
  xmlns:winUI="using:Microsoft.UI.Xaml.Controls"
      xmlns:tkWinUI="using:CommunityToolkit.WinUI"
      xmlns:uiNavigation="using:TsubameViewer.Views.UINavigation"  
  xmlns:vm="using:TsubameViewer.ViewModels" 
  xmlns:i18nExt="using:I18NPortable.Xaml.Extensions"
  xmlns:models="using:TsubameViewer.Core.Models" 
  xmlns:fluentIcon="using:Fluent.Icons"
      xmlns:winUIControls="using:CommunityToolkit.WinUI.Controls"
      xmlns:storage="using:Windows.Storage"
      xmlns:uwpControls1="using:CommunityToolkit.WinUI.Controls"
      mc:Ignorable="d"
    Background="{ThemeResource ApplicationContentBackgroundBrush}"
  NavigationCacheMode="Enabled"
  >
  <Page.Resources>
    <DataTemplate x:Name="TitlebarContent"
                  x:DataType="vm:FolderListupPageViewModel">
      <uwpControls:DockPanel>
        <StackPanel Orientation="Horizontal"
                    Grid.Column="1"
                    uwpControls:DockPanel.Dock="Right">
        </StackPanel>
        <StackPanel Orientation="Horizontal"
                    uwpControls:DockPanel.Dock="Left">
          
        </StackPanel>
        <AutoSuggestBox PlaceholderText="{i18nExt:Localize Key=SearchPlaceholder}"
                        QueryIcon="Find"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        x:Name="AutoSuggestBox"
                        Padding="0"                        
                        Width="196"
                        TextMemberPath="Title"
                        Text="{x:Bind FilterText, Mode=TwoWay}"
                        UpdateTextOnSelect="False"
                        AutoMaximizeSuggestionArea="True"
                        IsSuggestionListOpen="True"
                        IsFocusEngagementEnabled="True"
                        UseSystemFocusVisuals="True"
                        TextChanged="AutoSuggestBox_TextChanged"
                        SuggestionChosen="AutoSuggestBox_SuggestionChosen"
                        Loaded="PrimaryWindowCoreLayout_Loaded"
                        Unloaded="AutoSuggestBox_Unloaded"
                        FocusVisualSecondaryBrush="{ThemeResource SystemAccentColor}"
                        AccessKey="F"
                        AccessKeyInvoked="AutoSuggestBox_AccessKeyInvoked"
                        QuerySubmitted="AutoSuggestBox_QuerySubmitted"
                        >
          <AutoSuggestBox.TextBoxStyle>
            <Style TargetType="TextBox">
              <Setter Property="IsSpellCheckEnabled"
                      Value="False" />
            </Style>
          </AutoSuggestBox.TextBoxStyle>
          <i:Interaction.Behaviors>
            <!--<i:EventTriggerBehavior EventName="QuerySubmitted">
              <i:InvokeCommandAction Command="{x:Bind _vm.SearchQuerySubmitCommand}" InputConverter="{StaticResource AutoSuggestBoxQuerySubmittedEventArgsConverter}" />
            </i:EventTriggerBehavior>-->
            <uiNavigation:UINavigationTriggerBehavior Kind="Cancel"
                                                      IsRequireFocus="True">
              <i:CallMethodAction TargetObject="{Binding ElementName=AutoSuggestBox}"
                                     MethodName="RemoveFocusEngagement" />
            </uiNavigation:UINavigationTriggerBehavior>
          </i:Interaction.Behaviors>

          <AutoSuggestBox.KeyboardAccelerators>
            <KeyboardAccelerator Key="F"
                                 Modifiers="Control"
                                 Invoked="KeyboardAccelerator_Invoked" />
          </AutoSuggestBox.KeyboardAccelerators>

          <AutoSuggestBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}"
                         FontSize="12"
                         TextWrapping="Wrap" />
            </DataTemplate>
          </AutoSuggestBox.ItemTemplate>
        </AutoSuggestBox>

      </uwpControls:DockPanel>
    </DataTemplate>
  </Page.Resources>
  <Grid >

    <SplitView DisplayMode="Overlay"
               PanePlacement="Left"
               x:Name="FolderSelectionSplitView"
               OpenPaneLength="280">
      <SplitView.Pane>
        <uwpControls:DockPanel Margin="8 16 8 0">

          <StackPanel uwpControls:DockPanel.Dock="Top" Margin="0 0 0 16">
            <Button Command="{x:Bind MoveToFolderSelectedItemsCommand}"
                    CommandParameter="{x:Bind MoveToFolderTargetSelector.SelectedItem, Mode=OneWay}"
                    HorizontalAlignment="Stretch"
                    Style="{ThemeResource AccentButtonStyle}">
              <TextBlock Text="{i18nExt:Localize Key=MoveToFolder_ItemsMoveToSelectedFolder}" />
            </Button>
          </StackPanel>

          <ListView ItemsSource="{x:Bind Folders, Mode=OneWay}"
                    AllowDrop="True"
                    Drop="ListView_Drop"
                    DragEnter="ListView_DragEnter"
                    SelectionMode="Single"
                    x:Name="MoveToFolderTargetSelector"
                    Padding="0 0 0 48"
                    tkWinUI:ListViewExtensions.AlternateColor="{ThemeResource SystemBaseLowColor}"
                    FlowDirection="RightToLeft">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="storage:StorageFolder">
                <TextBlock Text="{x:Bind Name}" />
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </uwpControls:DockPanel>
      </SplitView.Pane>
      <uwpControls:DockPanel>

        <Grid x:Name="SelectActionsContainer"
              Visibility="Collapsed"
              uwpControls:DockPanel.Dock="Top"
              Background="{ThemeResource SystemChromeMediumHighColor}"
              BorderBrush="{ThemeResource SystemBaseMediumLowColor}"
              BorderThickness="0 0 0 1">
          <CommandBar DefaultLabelPosition="Right"
                      VerticalContentAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      MaxWidth="1600">
            <CommandBar.Content>

              <StackPanel Orientation="Horizontal"                          
                          Spacing="16">
                <Button Content="{i18nExt:Localize Key=MoveToFolder_ToggleSiblingFoldersDisplay}"
                        x:Name="ToggleDisplaySiblingFoldersButton"
                        IsEnabled="False"
                        Command="{x:Bind ToggleSiblingFolderPaneDisplayCommand}" />
                <TextBlock Text="{x:Bind _vm.SelectedCountDisplayText, Mode=OneWay}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </CommandBar.Content>

            <CommandBar.PrimaryCommands>
              <AppBarButton x:Name="CreateFolderButton"
                            Label="{i18nExt:Localize Key=CreateFolder}"
                            Command="{x:Bind CreateFolderCommand}"
                            AccessKey="B"
                            Visibility="{x:Bind _vm.IsFolderItemIsRawFolderAsVisible(_vm.CurrentFolderItem), Mode=OneWay}"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource SystemBaseLowColor}">
                <AppBarButton.Icon>
                  <SymbolIcon Symbol="Folder" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                  <KeyboardAccelerator Key="B" />
                </AppBarButton.KeyboardAccelerators>
              </AppBarButton>
              <AppBarButton Label="{i18nExt:Localize Key=Favorite_AddItem}"                            
                            BorderThickness="1"                            
                            BorderBrush="{ThemeResource SystemBaseLowColor}"
                            Command="{x:Bind _vm.FavoriteToggleCommand}"
                            CommandParameter="{x:Bind _vm.Selection.SelectedItems, Mode=OneWay}">
                <AppBarButton.Icon>
                  <SymbolIcon Symbol="Favorite" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                  <KeyboardAccelerator Key="O" />
                </AppBarButton.KeyboardAccelerators>
              </AppBarButton>
              <AppBarButton x:Name="SelectAction_StorageItemRemoveButton"
                            Label="{i18nExt:Localize Key=Delete}"
                            Command="{x:Bind _vm.FileDeleteCommand}"
                            CommandParameter="{x:Bind _vm.Selection.SelectedItems, Mode=OneWay}"
                            AccessKey="D"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource SystemBaseLowColor}">
                <AppBarButton.Icon>
                  <SymbolIcon Symbol="Delete" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                  <KeyboardAccelerator Key="Delete" />
                </AppBarButton.KeyboardAccelerators>
              </AppBarButton>
              <AppBarElementContainer VerticalContentAlignment="Stretch"
                                      IsTabStop="False"
                                      Margin="16 0 0 0">
                <Button Content="{i18nExt:Localize Key=Cancel}"
                        Click="{x:Bind _vm.Selection.EndSelection}"
                        AccessKey="Q"
                        Background="Transparent"
                        VerticalAlignment="Stretch"
                        Margin="0 6">
                  <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Escape" />
                  </Button.KeyboardAccelerators>
                </Button>
              </AppBarElementContainer>
            </CommandBar.PrimaryCommands>
          </CommandBar>
        </Grid>

        <StackPanel x:Name="HeaderLayout"
                    Background="{ThemeResource ApplicationContentBackgroundBrush}"
                    tkWinUI:FrameworkElementExtensions.EnableActualSizeBinding="True"
                    uwpControls:DockPanel.Dock="Top"
                    HorizontalAlignment="Stretch">
          <uwpControls:DockPanel x:Name="FilesActionLayout"
                                 Margin="0 16 0 8">

            <StackPanel uwpControls:DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        Visibility="{x:Bind _vm.DisplaySortTypeInheritancePath, Mode=OneWay, Converter={StaticResource StringNotEmptyToVisibleConverter}}">
              <TextBlock Opacity="0.7">
                <Run Text="{i18nExt:Localize Key=Sort_InheritancePath}" />: <Run Text="{x:Bind _vm.DisplaySortTypeInheritancePath, Mode=OneWay}" />
              </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        uwpControls:DockPanel.Dock="Left"
                        Spacing="8">
              <DropDownButton x:Name="FileSortButton"
                              Background="Transparent"
                              ToolTipService.ToolTip="{i18nExt:Localize Key=FileSortTitle}"
                              AccessKey="S"
                              CornerRadius="4">
                <TextBlock Text="{x:Bind _vm.SelectedFileSortType, Mode=OneWay, Converter={StaticResource LocalizeConverter}}" />
                <DropDownButton.Flyout>
                  <MenuFlyout>
                    <MenuFlyoutItem Text="{i18nExt:Localize Key=Sort_Unselected}"
                                    Command="{x:Bind _vm.ChangeFileSortCommand}"
                                    CommandParameter="{x:Null}" />
                    <MenuFlyoutItem Text="{i18nExt:Localize Key=FileSortType.UpdateTimeDecending}"
                                    Command="{x:Bind _vm.ChangeFileSortCommand}">
                      <MenuFlyoutItem.CommandParameter>
                        <folderModels:FileSortType>UpdateTimeDecending</folderModels:FileSortType>
                      </MenuFlyoutItem.CommandParameter>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="{i18nExt:Localize Key=FileSortType.UpdateTimeAscending}"
                                    Command="{x:Bind _vm.ChangeFileSortCommand}">
                      <MenuFlyoutItem.CommandParameter>
                        <folderModels:FileSortType>UpdateTimeAscending</folderModels:FileSortType>
                      </MenuFlyoutItem.CommandParameter>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="{i18nExt:Localize Key=FileSortType.TitleAscending}"
                                    Command="{x:Bind _vm.ChangeFileSortCommand}">
                      <MenuFlyoutItem.CommandParameter>
                        <folderModels:FileSortType>TitleAscending</folderModels:FileSortType>
                      </MenuFlyoutItem.CommandParameter>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="{i18nExt:Localize Key=FileSortType.TitleDecending}"
                                    Command="{x:Bind _vm.ChangeFileSortCommand}">
                      <MenuFlyoutItem.CommandParameter>
                        <folderModels:FileSortType>TitleDecending</folderModels:FileSortType>
                      </MenuFlyoutItem.CommandParameter>
                    </MenuFlyoutItem>
                  </MenuFlyout>
                </DropDownButton.Flyout>

                <DropDownButton.KeyboardAccelerators>
                  <KeyboardAccelerator Key="S"
                                       Modifiers="Control" />
                </DropDownButton.KeyboardAccelerators>
              </DropDownButton>
              <Button Margin="0 0 0 0">
                <Button.Content>
                  <SymbolIcon Symbol="More" />
                </Button.Content>

                <Button.Flyout>
                  <Flyout Placement="Bottom"
                          x:Name="ChildFolderSettingsFlyout"
                          Opened="ChildFolderSettingsFlyout_Opened">
                    <StackPanel Spacing="8">

                      <TextBlock x:Name="ChildImageFolderOpenModeButtonHeaderText"
                                 Text="{i18nExt:Localize Key=ChildImagesFolderOpenMode}"
                                 Visibility="Collapsed" />

                      <winUIControls:Segmented x:Name="ChildImageFolderOpenModeButton"
                                               Background="Transparent"
                                               Visibility="Collapsed"
                                               CornerRadius="4"
                                               ItemsSource="{x:Bind _vm.ChildImagesFolderOpenModeItems}"
                                               SelectedItem="{x:Bind _vm.SelectedChildImagesFolderOpenMode, Mode=OneWay}"
                                               SelectionChanged="ChildImageFolderOpenModeButton_SelectionChanged"
                                               ItemTemplate="{StaticResource LocalizeTextTemplate}">
                      </winUIControls:Segmented>

                      <TextBlock x:Name="ChildFolderSortButtonHeaderText"
                                 Text="{i18nExt:Localize Key=Sort_DefaultChildItemSort}"
                                 Visibility="Collapsed" />
                      <DropDownButton x:Name="ChildFolderSortButton"
                                      Content="{x:Bind _vm.SelectedChildFileSortType, Mode=OneWay, Converter={StaticResource LocalizeConverter}, FallbackValue=''}"
                                      Background="Transparent"
                                      Visibility="Collapsed"
                                      CornerRadius="4"
                                      MinHeight="32"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Left">
                        <DropDownButton.Flyout>
                          <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="{i18nExt:Localize Key=Sort_Unselected}"
                                            Command="{x:Bind _vm.ChangeChildFileSortCommand}"
                                            CommandParameter="{x:Null}">
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="{i18nExt:Localize Key=FileSortType.UpdateTimeDecending}"
                                            Command="{x:Bind _vm.ChangeChildFileSortCommand}">
                              <MenuFlyoutItem.CommandParameter>
                                <folderModels:FileSortType>UpdateTimeDecending</folderModels:FileSortType>
                              </MenuFlyoutItem.CommandParameter>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="{i18nExt:Localize Key=FileSortType.UpdateTimeAscending}"
                                            Command="{x:Bind _vm.ChangeChildFileSortCommand}">
                              <MenuFlyoutItem.CommandParameter>
                                <folderModels:FileSortType>UpdateTimeAscending</folderModels:FileSortType>
                              </MenuFlyoutItem.CommandParameter>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="{i18nExt:Localize Key=FileSortType.TitleAscending}"
                                            Command="{x:Bind _vm.ChangeChildFileSortCommand}">
                              <MenuFlyoutItem.CommandParameter>
                                <folderModels:FileSortType>TitleAscending</folderModels:FileSortType>
                              </MenuFlyoutItem.CommandParameter>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="{i18nExt:Localize Key=FileSortType.TitleDecending}"
                                            Command="{x:Bind _vm.ChangeChildFileSortCommand}">
                              <MenuFlyoutItem.CommandParameter>
                                <folderModels:FileSortType>TitleDecending</folderModels:FileSortType>
                              </MenuFlyoutItem.CommandParameter>
                            </MenuFlyoutItem>
                          </MenuFlyout>
                        </DropDownButton.Flyout>
                      </DropDownButton>
                    </StackPanel>
                  </Flyout>
                </Button.Flyout>
              </Button>
              <uwpControls:DockPanel Visibility="{x:Bind _vm.IsFavoriteAlbam, Mode=OneWay, Converter={StaticResource FalseToVisibleConverter}}">
                <ToggleSwitch IsOn="{x:Bind _vm.IsFavoriteFilteredDisplayEnabled, Mode=TwoWay}"
                              Style="{StaticResource ToggleSwitchNoHeader}"
                              uwpControls:DockPanel.Dock="Right"
                              Margin="8 0 0 0"
                              IsEnabled="{x:Bind _vm.IsReadyToFavoriteFilterDisplay, Mode=OneWay}"
                              />
                <TextBlock Text="{i18nExt:Localize Key=Favorite_ShowOnlyFavorite}" VerticalAlignment="Center" />
              </uwpControls:DockPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Margin="8 0"
                        uwpControls:DockPanel.Dock="Right">
              <Button Command="{x:Bind _vm.RefreshPageCommand}"
                      Visibility="{x:Bind _vm.RequireRefresh, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}"
                      Style="{ThemeResource AccentButtonStyle}"
                      Margin="8 0 16 0">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <SymbolIcon Symbol="Refresh" Style="{StaticResource TitlebarSymbolIcon}" />
                  <TextBlock Text="{i18nExt:Localize Key=Refresh}"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Border Visibility="{x:Bind _vm.HasFileItem, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}"
                      uwpControls:DockPanel.Dock="Right"
                      Margin="8 0 16 0">
                <winUIControls:Segmented uwpControls:DockPanel.Dock="Right"
                                         SelectionMode="Single"
                                         SelectionChanged="ContentViewTypeSelector_SelectionChanged"
                                         x:Name="ContentViewTypeSelector"
                                         AccessKey="L">
                  <winUIControls:SegmentedItem Content="{i18nExt:Localize Key=ChangeViewToFolderListupPage}"
                                               IsSelected="True"
                                               x:Name="ContentViewType_FolderListup" />
                  <winUIControls:SegmentedItem Content="{i18nExt:Localize Key=ChangeViewToImageListupPage}"                                               
                                               x:Name="ContentViewType_ImageListup" />
                </winUIControls:Segmented>
              </Border>

              <TextBlock VerticalAlignment="Center"
                         Visibility="{x:Bind _vm.NotEmptyToVisible(_vm.FilterText), Mode=OneWay}"
                         Margin="0 0 8 0"
                         Opacity="0.7">
              <Run Text="{x:Bind _vm.FileItemsView.Count, Mode=OneWay, Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='Search_FilteredDisplayItemsCount'}" />
              </TextBlock>
              <TextBlock Margin="0 0 0 0"
                         VerticalAlignment="Center"
                         Opacity="0.7">
              <Run Text="{x:Bind _vm.FolderItems.Count, Mode=OneWay, Converter={StaticResource LocalizeKeyAsParametersConverter}, ConverterParameter='Search_DisplayItemsCount'}" />
              </TextBlock>
            </StackPanel>

            <Border />
          </uwpControls:DockPanel>

          <Border Background="{ThemeResource SystemBaseLowColor}"
                  Height="1"
                  Opacity="0.5"></Border>
        </StackPanel>

        <uwpControls1:AdaptiveGridView ItemsSource="{x:Bind _vm.FileItemsView}"
                                      x:Name="FoldersAdaptiveGridView"
                                      StretchContentForSingleRow="False"
                                      OneRowModeEnabled="False"
                                      ItemTemplateSelector="{StaticResource FolderItemTemplateSelector}"
                                      ItemContainerStyle="{StaticResource FolderStyle}"
                                      DesiredWidth="{StaticResource FolderGridViewItemWidth}"
                                      ItemHeight="{StaticResource FolderGridViewItemHeight}"
                                      IsItemClickEnabled="True"
                                      ItemClickCommand="{x:Bind OpenItemCommand}"
                                      IsSynchronizedWithCurrentItem="False"
                                      SelectionMode="None"
                                      IsMultiSelectCheckBoxEnabled="True"
                                      IsTabStop="False"
                                      ContextFlyout="{StaticResource StorageItemMenuFlyout}"
                                       tkWinUI:ScrollViewerExtensions.VerticalScrollBarMargin="0 0 0 0"
                                      XYFocusUp="{x:Bind FileSortButton}"
                                      SelectedItem="{x:Bind _vm.FolderLastIntractItem, Mode=TwoWay}"
                                      SelectionChanged="OnSelectionChanged"
                                      CanDragItems="True"
                                      DragItemsStarting="FoldersAdaptiveGridView_DragItemsStarting"
                                      DragItemsCompleted="FoldersAdaptiveGridView_DragItemsCompleted"
                                      AllowDrop="True">

          <GridView.Header>
            <Grid Visibility="{x:Bind _vm.FileItemsView.Count, Mode=OneWay, Converter={StaticResource ZeroToVisibleConverter}}"
                  Opacity="{x:Bind _vm.NowProcessing, Mode=OneWay, Converter={StaticResource FalseToDouble1Converter}}">
              <TextBlock Text="{i18nExt:Localize Key=NoItems}"
                         Style="{StaticResource SubtitleTextBlockStyle}"
                         Opacity="0.5"
                         HorizontalAlignment="Center"
                         Margin="32" />
            </Grid>
          </GridView.Header>
          <GridView.ItemContainerTransitions>
            <TransitionCollection />
          </GridView.ItemContainerTransitions>

          <i:Interaction.Behaviors>
            <uiNavigation:UINavigationTriggerBehavior Kind="Context1">
              <uiNavigation:BypassToCurrentFocusElementDataContextAction>
                <i:InvokeCommandAction Command="{x:Bind SelectionChangeCommand}" />
              </uiNavigation:BypassToCurrentFocusElementDataContextAction>
            </uiNavigation:UINavigationTriggerBehavior>
          </i:Interaction.Behaviors>

        </uwpControls1:AdaptiveGridView>

      </uwpControls:DockPanel>

    </SplitView>

    <ContentDialog x:Name="CreateFolderDialog"
                   Padding="0 48 0 0"
                   PrimaryButtonText="{i18nExt:Localize Key=Create}"
                   SecondaryButtonText="{i18nExt:Localize Key=Cancel}"
                   Title="{i18nExt:Localize Key=CreateFolder}">
      <StackPanel MinHeight="60">
        <TextBox x:Name="CreateFolderDialogTextBox"
                 AcceptsReturn="False"
                 VerticalAlignment="Top" 
                 MaxLength="100"
                 PlaceholderText="{i18nExt:Localize Key=CreateFolder_FolderNamePlaceholder}"
                 Margin="0 0 0 8" />
        <TextBlock Text="{i18nExt:Localize Key=CreateFolder_ExistFolderName}" 
                   Visibility="Collapsed"
                   x:Name="CreateFolder_ExistFolderNameTextBlock"
                   Foreground="{ThemeResource SystemErrorTextColor}"
                   />
      </StackPanel>
    </ContentDialog>

    <VisualStateManager.VisualStateGroups>

      <!-- 選択中の表示 -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind _vm.Selection.IsSelectionModeEnabled, Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.SelectionMode" Value="Multiple" />
            <Setter Target="SelectActionsContainer.Visibility" Value="Visible" />
            <!--
            <Setter Target="ContentViewTypeSelector.IsEnabled" Value="False" />
            -->
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
      
      <!-- フォルダまたはアーカイブ内フォルダかによる表示切替 -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{Binding CurrentFolderItem.StorageItemTypesIsFolder}" />
            <!--
            <wst:EqualsStateTrigger Value="{Binding CurrentFolderItem.Type}" EqualTo="{x:Bind models:StorageItemTypes.Folder}" />
              -->
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="ChildFolderSortButton.Visibility" Value="Visible" />
            <Setter Target="ChildFolderSortButtonHeaderText.Visibility" Value="Visible" />
            <Setter Target="ChildImageFolderOpenModeButton.Visibility" Value="Visible" />
            <Setter Target="ChildImageFolderOpenModeButtonHeaderText.Visibility" Value="Visible" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
      
      <!-- 表示内容切替中の全体の表示切替 -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <!-- x:Bind _vm.NowProcessing だと反映されないのでBindingを使用 -->
            <StateTrigger IsActive="{Binding NowProcessing}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FileSortButton.IsEnabled" Value="False" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
      
      <!-- フォルダアイテムが無い時のフォルダリストの非表示切り替え -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <wst:EqualsStateTrigger Value="{x:Bind _vm.FolderItems.Count, Mode=OneWay}" EqualTo="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
     
      
      <!-- 画面サイズによる表示切り替え -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <wst:DeviceFamilyStateTrigger DeviceFamily="Xbox" />
            <StateTrigger IsActive="{StaticResource DebugTVMode}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding" Value="48 0 48 27" />
            <Setter Target="HeaderLayout.Padding" Value="48 0 48 0" />
            <Setter Target="SelectActionsContainer.Padding" Value="48 0 48 0" />            
            <Setter Target="FolderSelectionSplitView.DisplayMode" Value="Inline" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1600" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding" Value="280 0 280 32" />
            <Setter Target="HeaderLayout.Padding" Value="280 0 280 0" />
            <Setter Target="SelectActionsContainer.Padding" Value="280 0 280 0" />            
            <Setter Target="FolderSelectionSplitView.DisplayMode" Value="Inline" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1220" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding" Value="140 0 140 32" />
            <Setter Target="HeaderLayout.Padding" Value="140 0 140 0" />
            <Setter Target="SelectActionsContainer.Padding" Value="140 0 140 0" />            
            <Setter Target="FolderSelectionSplitView.DisplayMode" Value="Inline" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="610" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding" Value="48 0 48 32" />
            <Setter Target="HeaderLayout.Padding" Value="48 0 48 0" />            
            <Setter Target="SelectActionsContainer.Padding" Value="48 0 48 0" />            
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding" Value="8 0 8 32" />
            <Setter Target="HeaderLayout.Padding" Value="8 0 8 0" />
            <Setter Target="SelectActionsContainer.Padding" Value="8 0 8 0" />

            <Setter Target="ContentViewType_FolderListup.Content">
              <Setter.Value>
                <fluentIcon:FluentSymbolIcon Symbol="Folder24"
                                             Margin="0 0 0 2" />
              </Setter.Value>
            </Setter>
            <Setter Target="ContentViewType_ImageListup.Content">
              <Setter.Value>
                <fluentIcon:FluentSymbolIcon Symbol="Image24"
                                             Margin="0 0 2 2" />
              </Setter.Value>
            </Setter>
