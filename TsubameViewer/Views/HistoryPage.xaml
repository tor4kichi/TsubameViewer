<Page
    x:Class="TsubameViewer.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TsubameViewer.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
      xmlns:ts="using:TsubameViewer.Views.TemplateSelector"
      xmlns:uwpControls="using:Microsoft.Toolkit.Uwp.UI.Controls"
      xmlns:i="using:Microsoft.Xaml.Interactivity"
      xmlns:core="using:Microsoft.Xaml.Interactions.Core"
      xmlns:wst="using:WindowsStateTriggers"
      xmlns:myBehaior="using:TsubameViewer.Views.Behaviors"
      xmlns:ss="using:TsubameViewer.Views.StyleSelector"
      xmlns:vm="using:TsubameViewer.ViewModels"
      xmlns:myFlyouts="using:TsubameViewer.Views.Flyouts"
      xmlns:i18nExt="using:I18NPortable.Xaml.Extensions"
      xmlns:uiNavigation="using:TsubameViewer.Views.UINavigation"
      Background="{ThemeResource ApplicationContentBackgroundBrush}">

  <Page.Resources>
    <DataTemplate x:Name="TitlebarContent"
                  x:DataType="vm:HistoryPageViewModel">
      <uwpControls:DockPanel>

        <StackPanel Orientation="Horizontal"
                    uwpControls:DockPanel.Dock="Right" Spacing="8">
          <TextBlock Opacity="0.7"
                     VerticalAlignment="Center">
            <Run Text="{x:Bind RecentlyItems.Count, Mode=OneWay}" />/100
          </TextBlock>

          <Button Style="{StaticResource TitlebarButton}">
            <SymbolIcon Symbol="Delete" />

            <Button.Flyout>
              <MenuFlyout Placement="Bottom">
                <MenuFlyoutItem Text="{i18nExt:Localize Key=HistoryPage_RemoveAll}"
                                Command="{x:Bind RemoveAllHistoryCommand}"/>
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>
        <AutoSuggestBox PlaceholderText="{i18nExt:Localize Key=SearchPlaceholder}"
                        Text="{x:Bind FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        QueryIcon="Find"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        x:Name="AutoSuggestBox"
                        Padding="0"
                        Margin="0 0 8 0"
                        MinWidth="176"
                        TextMemberPath="Title"
                        UpdateTextOnSelect="False"
                        AutoMaximizeSuggestionArea="True"
                        IsSuggestionListOpen="True"
                        IsFocusEngagementEnabled="True"
                        UseSystemFocusVisuals="True"
                        TextChanged="AutoSuggestBox_TextChanged"
                        SuggestionChosen="AutoSuggestBox_SuggestionChosen"
                        Loaded="PrimaryWindowCoreLayout_Loaded"
                        Unloaded="AutoSuggestBox_Unloaded"
                        FocusVisualSecondaryBrush="{ThemeResource SystemAccentColor}"
                        AccessKey="F"
                        AccessKeyInvoked="AutoSuggestBox_AccessKeyInvoked"
                        QuerySubmitted="AutoSuggestBox_QuerySubmitted">
          <i:Interaction.Behaviors>
            <!--<core:EventTriggerBehavior EventName="QuerySubmitted">
  <core:InvokeCommandAction Command="{x:Bind _vm.SearchQuerySubmitCommand}" InputConverter="{StaticResource AutoSuggestBoxQuerySubmittedEventArgsConverter}" />
</core:EventTriggerBehavior>-->
            <uiNavigation:UINavigationTriggerBehavior Kind="Cancel"
                                                      IsRequireFocus="True">
              <core:CallMethodAction TargetObject="{Binding ElementName=AutoSuggestBox}"
                                     MethodName="RemoveFocusEngagement" />
            </uiNavigation:UINavigationTriggerBehavior>
          </i:Interaction.Behaviors>

          <AutoSuggestBox.KeyboardAccelerators>
            <KeyboardAccelerator Key="F"
                                 Modifiers="Control"
                                 Invoked="KeyboardAccelerator_Invoked" />
          </AutoSuggestBox.KeyboardAccelerators>

          <AutoSuggestBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}"
                         FontSize="12"
                         TextWrapping="Wrap" />
            </DataTemplate>
          </AutoSuggestBox.ItemTemplate>
        </AutoSuggestBox>
      </uwpControls:DockPanel>
    </DataTemplate>

  </Page.Resources>
  <Grid>
    <VisualStateManager.VisualStateGroups>
      <!-- 画面サイズによる表示切り替え -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <wst:DeviceFamilyStateTrigger DeviceFamily="Xbox" />
            <StateTrigger IsActive="{StaticResource DebugTVMode}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding"
                    Value="48 0 48 27" />
            <!--<Setter Target="HeaderLayout.Padding"
                    Value="48 0" />-->
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1600" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding"
                    Value="280 0 280 32" />
            <!--<Setter Target="HeaderLayout.Padding"
                    Value="280 0" />-->
          </VisualState.Setters>
        </VisualState>

        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1220" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding"
                    Value="140 0 140 32" />
            <!--<Setter Target="HeaderLayout.Padding"
                    Value="140 0" />-->
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="610" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding"
                    Value="48 0 48 32" />
            <!--<Setter Target="HeaderLayout.Padding"
                    Value="48 0" />-->
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="FoldersAdaptiveGridView.Padding"
                    Value="8 0 8 32" />
            <!--<Setter Target="HeaderLayout.Padding"
                    Value="8 0" />-->
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>
    <uwpControls:DockPanel >

      <!--<uwpControls:DockPanel x:Name="HeaderLayout"
                             uwpControls:DockPanel.Dock="Top"
                             MaxWidth="960"
                             Margin="32 8 32 8">
        
        <TextBlock Text="{i18nExt:Localize Key=HistoryPage_Title}"
                   uwpControls:DockPanel.Dock="Left"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          
        </StackPanel>
      </uwpControls:DockPanel>-->

      <uwpControls:AdaptiveGridView x:Name="FoldersAdaptiveGridView"
                                    StretchContentForSingleRow="False"
                                    OneRowModeEnabled="False"
                                    ItemsSource="{x:Bind _vm.FilteredItems}"
                                    ItemTemplateSelector="{StaticResource FolderItemTemplateSelector}"
                                    ItemContainerStyleSelector="{StaticResource FolderItemStyleSelector}"
                                    DesiredWidth="{StaticResource FolderGridViewItemWidth}"
                                    ItemHeight="160"
                                    IsItemClickEnabled="True"
                                    ItemClickCommand="{x:Bind _vm.OpenFolderItemCommand}"
                                    IsSynchronizedWithCurrentItem="False"
                                    SelectionMode="None"
                                    ContextFlyout="{StaticResource StorageItemMenuFlyout}"
                                    Padding="16 8 16 72">
        <!-- 表示がチラつくのでGridViewItemのアニメーションを無効にしている -->
        <GridView.ItemContainerTransitions>
          <TransitionCollection />
        </GridView.ItemContainerTransitions>

        <uwpControls:AdaptiveGridView.Header>
          <Grid Visibility="{x:Bind _vm.RecentlyItems.Count, Mode=OneWay, Converter={StaticResource ZeroToVisibleConverter}}">
            <TextBlock Text="{i18nExt:Localize Key=NoItems}"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Opacity="0.5"
                       HorizontalAlignment="Center"
                       Margin="32"
                       />
          </Grid>
        </uwpControls:AdaptiveGridView.Header>
        <!--<GridView.GroupStyle>
        <GroupStyle HidesIfEmpty="True">
          <GroupStyle.HeaderTemplate>
            <DataTemplate x:DataType="vm:SourceItemsGroup">
              <TextBlock Text="{x:Bind GroupId, Converter={StaticResource LocalizeConverter}}" />
            </DataTemplate>
          </GroupStyle.HeaderTemplate>
          <GroupStyle.HeaderContainerStyle>
            <Style TargetType="GridViewHeaderItem">
              <Setter Property="IsTabStop"
                      Value="False" />
            </Style>
          </GroupStyle.HeaderContainerStyle>
        </GroupStyle>
      </GridView.GroupStyle>-->
      </uwpControls:AdaptiveGridView>
    </uwpControls:DockPanel>
    
  </Grid>
</Page>
