<UserControl
    x:Class="TsubameViewer.Views.AppShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TsubameViewer.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
  xmlns:i="using:Microsoft.Xaml.Interactivity"
  xmlns:core="using:Microsoft.Xaml.Interactions.Core"
  xmlns:ts="using:TsubameViewer.Views.TemplateSelector"
  xmlns:uwpControls="using:Microsoft.Toolkit.Uwp.UI.Controls"
  xmlns:uwpExtensions="using:Microsoft.Toolkit.Uwp.UI"
  xmlns:wst="using:WindowsStateTriggers" 
  xmlns:myConv="using:TsubameViewer.Views.Converters" 
  xmlns:mySS="using:TsubameViewer.Views.StyleSelector" 
  xmlns:viewModel="using:TsubameViewer.ViewModels"
  xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
  xmlns:i18Ext="using:I18NPortable.Xaml.Extensions"
  xmlns:animations="using:Microsoft.Toolkit.Uwp.UI.Animations"
  xmlns:uiNavigation="using:TsubameViewer.Views.UINavigation"
  xmlns:fi="using:Fluent.Icons"
             xmlns:myStateTriggers="using:TsubameViewer.Views.StateTrigger"
             mc:Ignorable="d"
             xmlns:Windows10version1903="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract, 8)"
             Background="{ThemeResource ApplicationContentBackgroundBrush}"
  >
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="NavigationViewTopPaneBackground"
                           Color="{ThemeResource SystemChromeMediumColor}" />
          <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground"
                           Color="{ThemeResource SystemChromeMediumColor}" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="NavigationViewTopPaneBackground"
                           Color="{ThemeResource SystemChromeMediumColor}" />
          <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground"
                           Color="{ThemeResource SystemChromeMediumColor}" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

      <myConv:AutoSuggestBoxQuerySubmittedEventArgsConverter x:Key="AutoSuggestBoxQuerySubmittedEventArgsConverter" />

      <!--<CollectionViewSource x:Key="AutoSuggestBoxItems"
                          Source="{x:Bind _vm.AutoSuggestBoxItems}"
                          IsSourceGrouped="True"
                          ItemsPath="Items"
                          >

      </CollectionViewSource>-->

      <local:MenuItemTemplateSelector x:Key="MenuItemTemplateSelector">
        <local:MenuItemTemplateSelector.MenuSeparator>
          <DataTemplate>
            <Border BorderThickness="0 1 0 0"
                    BorderBrush="{ThemeResource AppBarBorderThemeBrush}" />
          </DataTemplate>
        </local:MenuItemTemplateSelector.MenuSeparator>
        <local:MenuItemTemplateSelector.MenuItem>
          <DataTemplate x:DataType="viewModel:MenuItemViewModel">
            <TextBlock Text="{x:Bind PageType, Converter={StaticResource LocalizeConverter}}" />
          </DataTemplate>
        </local:MenuItemTemplateSelector.MenuItem>
      </local:MenuItemTemplateSelector>

      <Thickness x:Key="NavigationViewHeaderMargin">0</Thickness>
      <Thickness x:Key="NavigationViewBorderThickness">0</Thickness>

      <local:MenuItemDateTemplateSelector x:Key="MenuItemDateTemplateSelector">
        <local:MenuItemDateTemplateSelector.Item>
          <DataTemplate x:DataType="viewModel:MenuItemViewModel">
            <muxc:NavigationViewItem Content="{x:Bind Title}"
                                     AccessKey="{x:Bind AccessKey}"
                                     DataContext="{x:Bind}"
                                     Tag="{x:Bind}"
                                     Tapped="NavigationViewItem_Tapped"
                                     FlowDirection="RightToLeft"
                                     AllowDrop="True"
                                     DragEnter="NavigationViewItem_DragEnter"
                                     Drop="NavigationViewItem_Drop">
              <muxc:NavigationViewItem.KeyboardAccelerators>
                <KeyboardAccelerator Key="{x:Bind KeyboardAceseralator}"
                                     Modifiers="Control" />
              </muxc:NavigationViewItem.KeyboardAccelerators>
            </muxc:NavigationViewItem>
          </DataTemplate>
        </local:MenuItemDateTemplateSelector.Item>
        <local:MenuItemDateTemplateSelector.ItemInvoke>
          <DataTemplate x:DataType="viewModel:MenuItemInvokeActionViewModel">
            <muxc:NavigationViewItem Content="{x:Bind Title}" 
                                     AccessKey="{x:Bind AccessKey}"
                                     DataContext="{x:Bind}"
                                     Tag="{x:Bind}"
                                     Tapped="NavigationViewItem_Tapped"
                                     ToolTipService.ToolTip="{x:Bind Tooltip}"
                                     Icon="{Binding Icon}"
                                     IsSelected="False"
                                     FlowDirection="RightToLeft">
              <muxc:NavigationViewItem.KeyboardAccelerators>
                <KeyboardAccelerator Key="{x:Bind KeyboardAceseralator}"
                                     Modifiers="Control" />
              </muxc:NavigationViewItem.KeyboardAccelerators>
            </muxc:NavigationViewItem>
          </DataTemplate>
        </local:MenuItemDateTemplateSelector.ItemInvoke>
        <local:MenuItemDateTemplateSelector.SubItem>
          <DataTemplate x:DataType="viewModel:MenuSubItemViewModel">
            <muxc:NavigationViewItem Content="{x:Bind Title}"
                                     MenuItemsSource="{x:Bind Items}"
                                     AccessKey="{x:Bind AccessKey}"
                                     DataContext="{x:Bind}"
                                     Tag="{x:Bind}"
                                     Tapped="NavigationViewItem_Tapped"
                                     IsExpanded="False"
                                     Icon="{Binding Icon}"
                                     FlowDirection="RightToLeft">
            </muxc:NavigationViewItem>
          </DataTemplate>
        </local:MenuItemDateTemplateSelector.SubItem>
        <local:MenuItemDateTemplateSelector.Separator>
          <DataTemplate x:DataType="viewModel:MenuSeparatorViewModel">
            <muxc:NavigationViewItemSeparator />
          </DataTemplate>
        </local:MenuItemDateTemplateSelector.Separator>
      </local:MenuItemDateTemplateSelector>

      <Flyout x:Name="PurchaseThanksMassageFlyout">
        <TextBlock Text="{i18Ext:Localize Key=PurchaseAddon_PurchasedThanksMessage}"
                   TextWrapping="Wrap"
                   MaxWidth="320" />
      </Flyout>

      <Flyout x:Name="PurchaseConfirmFlyout">
        <StackPanel Spacing="16"
                    MaxWidth="300">

          <TextBlock Text="{i18Ext:Localize Key=PurchaseAddon_ButtonTitle}"
                     Style="{StaticResource SubtitleTextBlockStyle}" />

          <TextBlock x:Name="PurchaseConfirmFlyout_DescTextBlock"
                     Text=""
                     TextWrapping="Wrap"
                     MinHeight="60"
                     Margin="0 0 0 0" />

          <Button Content="{i18Ext:Localize Key=PurchaseAddon_ShowPurchaseUI}"
                  Command="{x:Bind PurchaseAddonCommand}"
                  HorizontalAlignment="Stretch"
                  Style="{StaticResource AccentButtonStyle}" />

          <HyperlinkButton Content="{i18Ext:Localize Key=PurchaseAddon_ShowPurchaseHistory}"
                           NavigateUri="https://account.microsoft.com/billing/orders"
                           HorizontalAlignment="Stretch" />
        </StackPanel>
      </Flyout>

    </ResourceDictionary>
  </UserControl.Resources>
  <Grid AllowDrop="True" DragEnter="Grid_DragEnter" Drop="Grid_Drop"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        x:Name="RootGrid"
        >

    <Grid Opacity="0"
          IsHitTestVisible="False">
      <Button>
        <Button.KeyboardAccelerators>
          <KeyboardAccelerator Key="F5"
                               Invoked="RefreshPageKeyboardAccelerator_Invoked" />
          <KeyboardAccelerator Key="F11"
                               Invoked="ToggleFullScreenKeyboardAccelerator_Invoked" />
          <KeyboardAccelerator Key="Escape"
                               Invoked="ExitViewerKeyboardAccelerator_Invoked" />
        </Button.KeyboardAccelerators>
      </Button>
    </Grid>
    <muxc:NavigationView x:Name="MyNavigationView"
                         uwpControls:DockPanel.Dock="Top"
                         MenuItemsSource="{Binding MenuItems}"
                         MenuItemTemplateSelector="{StaticResource MenuItemDateTemplateSelector}"
                         FooterMenuItemsSource="{x:Bind _footerItemsForTop}"
                         PaneDisplayMode="{x:Bind ToPaneDisplayMode(_vm.ApplicationSettings.IsAppMenuShowWithLeft), Mode=OneWay}"
                         OpenPaneLength="200"
                         IsSettingsVisible="False"
                         ItemInvoked="MyNavigationView_ItemInvoked"
                         IsBackButtonVisible="Collapsed"
                         XYFocusDownNavigationStrategy="Projection"
                         SelectionFollowsFocus="Disabled"
                         IsPaneToggleButtonVisible="False"
                         Background="{ThemeResource ApplicationContentBackgroundBrush}">
      <UIElement.RenderTransform>
        <TranslateTransform />
      </UIElement.RenderTransform>
      <muxc:NavigationView.PaneHeader>
        <Border x:Name="NavigationViewHeader">
          <Border Windows10version1903:Translation="0, 0, 8"
                  VerticalAlignment="Top"
                  Height="16"
                  Background="Transparent">
            <Border.RenderTransform>
              <TranslateTransform Y="-19" />
            </Border.RenderTransform>
            <Windows10version1903:Border.Shadow>
              <Windows10version1903:ThemeShadow />
            </Windows10version1903:Border.Shadow>
          </Border>
        </Border>
      </muxc:NavigationView.PaneHeader>
      
      <i:Interaction.Behaviors>
        <!--
        <core:EventTriggerBehavior EventName="ItemInvoked">
          <core:InvokeCommandAction Command="{x:Bind _vm.OpenMenuItemCommand}" InputConverter="{StaticResource NavigationViewItemInvokedEventArgsConverter}" />
        </core:EventTriggerBehavior>
        -->
      </i:Interaction.Behaviors>

      <Grid>
        <Frame x:Name="ContentFrame"
               DataContext="{x:Null}"
               CacheSize="5"
               XYFocusDownNavigationStrategy="RectilinearDistance">
        </Frame>
        <Border Windows10version1903:Translation="0, 0, 8"
                VerticalAlignment="Top"
                Height="16"
                Background="Transparent">
          <Border.RenderTransform>
            <TranslateTransform Y="-17" />
          </Border.RenderTransform>
          <Windows10version1903:Border.Shadow>
            <Windows10version1903:ThemeShadow />
          </Windows10version1903:Border.Shadow>
        </Border>
        <Border Windows10version1903:Translation="0, 0, 8"
                HorizontalAlignment="Left"
                Width="32"
                Background="Transparent">
          <Border.RenderTransform>
            <TranslateTransform X="-32" />
          </Border.RenderTransform>
          <Windows10version1903:Border.Shadow>
            <Windows10version1903:ThemeShadow />
          </Windows10version1903:Border.Shadow>
        </Border>

      </Grid>
    </muxc:NavigationView>

    <Frame x:Name="ViewerFrame"
           DataContext="{x:Null}"
           CacheSize="0"
           Visibility="Collapsed"
           Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
           >
      <UIElement.RenderTransform>
        <TranslateTransform />
      </UIElement.RenderTransform>
    </Frame>

    <Border x:Name="TitlebarBG"
                           VerticalAlignment="Top"
                           Height="48"
                           Background="{ThemeResource SystemChromeMediumColor}">
      <UIElement.RenderTransform>
        <TranslateTransform />
      </UIElement.RenderTransform>

      <Border VerticalAlignment="Bottom"
              Height="1"
              Background="{ThemeResource SystemBaseLowColor}"
              Opacity="0.2"/>
    </Border>

    <uwpControls:DockPanel x:Name="TitlebarUIContainer"
                           VerticalAlignment="Top"
                           Height="48">
      <UIElement.RenderTransform>
        <TranslateTransform />
      </UIElement.RenderTransform>

      <Button Command="{x:Bind _vm.BackNavigationCommand}"
              x:Name="GoBackButton"
              uwpControls:DockPanel.Dock="Left"
              Margin="8 4"
              VerticalAlignment="Center">
        <SymbolIcon Symbol="Back"
                    Style="{StaticResource TitlebarSymbolIcon}">
          
        </SymbolIcon>
      </Button>

      <StackPanel Orientation="Horizontal"
                  Margin="8 0 8 0"
                  uwpControls:DockPanel.Dock="Left"
                  Spacing="8"
                  x:Name="TitleIconAndTextContainer_Wide">
        <Image Source="/Assets/Square44x44Logo.png"
               Width="24"
               VerticalAlignment="Center"
               uwpControls:DockPanel.Dock="Left" />
        <TextBlock x:Name="WindowTitleTextBlock"
                   VerticalAlignment="Center"
                   TextLineBounds="Tight"                   
                   TextTrimming="CharacterEllipsis"
                   Style="{StaticResource TitlebarTextBlock}"
                   MaxWidth="300"
                   ToolTipService.ToolTip="{x:Bind WindowTitleTextBlock.Text, Mode=OneWay}"
                   ToolTipService.Placement="Bottom" />
      </StackPanel>

      <StackPanel x:Name="TitleIconAndTextContainer_Nallow"
                  Visibility="Collapsed"
                  VerticalAlignment="Center">
        <muxc:DropDownButton Height="40" Background="Transparent"
                             BorderThickness="1 0 1 0">
          <Image Source="/Assets/Square44x44Logo.png"
                 Width="24"
                 VerticalAlignment="Center"
                 uwpControls:DockPanel.Dock="Left" />

          <muxc:DropDownButton.Flyout>
            <Flyout>
              <StackPanel>
                <TextBlock x:Name="WindowTitleTextBlock_Nallow"
                           Text="{x:Bind WindowTitleTextBlock.Text, Mode=OneWay}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Style="{StaticResource TitlebarTextBlock}"
                           TextWrapping="Wrap"
                           MaxWidth="300" />

                <ContentControl x:Name="TitlebarContent_Nallow"
                      HorizontalContentAlignment="Stretch"
                      Margin="0 8 0 0"
                      VerticalAlignment="Top"
                      Height="48"
                      VerticalContentAlignment="Stretch"                      
                      >
                <UIElement.RenderTransform>
                  <TranslateTransform />
                </UIElement.RenderTransform>
                </ContentControl>
              </StackPanel>
            </Flyout>
          </muxc:DropDownButton.Flyout>
        </muxc:DropDownButton>
      </StackPanel>

      <StackPanel Orientation="Horizontal"
                  Margin="16 0 184 0"
                  HorizontalAlignment="Right"
                  uwpControls:DockPanel.Dock="Right">

        <Button Command="{x:Bind ShowPackageUpdateUICommand}"
                Visibility="{x:Bind NowAvairableUpdate, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}"
                ToolTipService.ToolTip="App Update">
          <SymbolIcon Symbol="Refresh" />
        </Button>

        <Button uwpControls:DockPanel.Dock="Right"
                Style="{StaticResource TitlebarButton}"
                x:Name="FeedbackButton"
                ToolTipService.ToolTip="{i18Ext:Localize Key=SendFeedbackWithMashmallow}"
                >
          <SymbolIcon Symbol="Send" Style="{StaticResource TitlebarSymbolIcon}" />

          <Button.Flyout>
            <MenuFlyout Placement="Bottom">
              <MenuFlyoutItem Text="{i18Ext:Localize Key=SendFeedbackWithMashmallow}"
                              Command="{x:Bind _vm.SendFeedbackWithMashmallowCommand}" />

              <MenuFlyoutItem Text="{i18Ext:Localize Key=SendFeedbackWithStoreReview}"
                              Command="{x:Bind _vm.SendFeedbackWithStoreReviewCommand}" />

              <MenuFlyoutItem Text="{i18Ext:Localize Key=PurchaseAddon_ButtonTitle}"
                              Click="ShowPurchaseConfirmFlyoutMenuFlyoutItem_Click" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>
      </StackPanel>
      
      <ContentControl x:Name="TitlebarContent"
                      HorizontalContentAlignment="Stretch"
                      Margin="8 1 0 0"
                      VerticalAlignment="Top"
                      Height="48"
                      VerticalContentAlignment="Stretch"                      
                      >
        <UIElement.RenderTransform>
          <TranslateTransform />
        </UIElement.RenderTransform>
      </ContentControl>
    </uwpControls:DockPanel>

    

    <Grid x:Name="BusyWall" IsHitTestVisible="False" Opacity="0" Visibility="Collapsed">
      <Grid.Background>
        <SolidColorBrush Color="{ThemeResource SystemAltLowColor}" Opacity="0.5" />
      </Grid.Background>
      <StackPanel Spacing="32" VerticalAlignment="Center"
                  HorizontalAlignment="Stretch"
                  Background="{ThemeResource SystemChromeAltHighColor}"
                  Padding="48"
                  >

        <muxc:ProgressRing x:Name="BusyWall_ProgressRing" IsActive="False"
                         IsIndeterminate="True"
                           Height="64"
                           Width="64"
                           HorizontalAlignment="Center"
                         />

        <Button Content="{i18Ext:Localize Key=Cancel}"
                Command="{x:Bind CancelBusyWorkCommand}"
                MinWidth="200"
                Height="48"
                HorizontalAlignment="Center"
                Style="{ThemeResource AccentButtonStyle}"
                AccessKey="C"
                x:Name="BusyWallCancelButton"
                />


      </StackPanel>
    </Grid>

    <Grid x:Name="NotificationContainer"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"    
            Padding="24 12"
            Background="{ThemeResource SystemChromeMediumLowColor}"
            BorderBrush="{ThemeResource SystemBaseLowColor}"
            BorderThickness="1"
            CornerRadius="6"
            Margin="16 64 16 16"
            IsHitTestVisible="False"            
            >
      <ContentControl x:Name="NotificationContentControl"
                      Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                      IsHitTestVisible="False"
                      IsTabStop="False"                      
                      FontSize="16"
                      MaxWidth="320"
                    >
      </ContentControl>

      <TextBlock x:Name="NotificationTextBlock"
                      Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                      IsHitTestVisible="False"
                      FontSize="16"
                      MaxWidth="320"
                 TextWrapping="Wrap"
                 MaxLines="3">
      </TextBlock>
    </Grid>
       
    <!--
    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Bottom">
      <Button Content="Show BusyWall">
        <i:Interaction.Behaviors>
          <core:EventTriggerBehavior EventName="Tapped">
            <core:GoToStateAction StateName="VS_ShowBusyWall" />
          </core:EventTriggerBehavior>
        </i:Interaction.Behaviors>
      </Button>
      <Button Content="Hide BusyWall">
        <i:Interaction.Behaviors>
          <core:EventTriggerBehavior EventName="Tapped">
            <core:GoToStateAction StateName="VS_HideBusyWall" />
          </core:EventTriggerBehavior>
        </i:Interaction.Behaviors>
      </Button>
    </StackPanel>
    -->
    
    <Grid Background="{ThemeResource SystemAltMediumColor}"
          x:Name="PackageUpdateDialogBGWall"
          Visibility="Collapsed"
          IsHitTestVisible="True"
          Tapped="PackageUpdateDialogBGWall_Tapped">
      <muxc:ProgressRing IsActive="True"
                         x:Name="PackageUpdateProgressRing" 
                         HorizontalAlignment="Center" 
                         VerticalAlignment="Center"
                         Width="80"
                         Height="80"/>
    </Grid>
    <ContentDialog x:Name="PackageUpdateDialog"
                   Title="{i18Ext:Localize Key=NowAvairableUpdate}"
                   PrimaryButtonText="{i18Ext:Localize Key=Update}"
                   PrimaryButtonStyle="{ThemeResource AccentButtonStyle}"
                   SecondaryButtonText="{i18Ext:Localize Key=Cancel}"
                   DefaultButton="Primary">
      <HyperlinkButton NavigateUri="https://tor4kichi.github.io/tsubame_viewer/updates">
        <TextBlock Text="{i18Ext:Localize Key=OpenUpdateHistoryWithBrowser}" />
      </HyperlinkButton>
    </ContentDialog>
    
    <VisualStateManager.VisualStateGroups>

      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <wst:EqualsStateTrigger Value="{Binding ElementName=MyNavigationView, Path=PaneDisplayMode}">
              <wst:EqualsStateTrigger.EqualTo>
                <muxc:NavigationViewPaneDisplayMode>Left</muxc:NavigationViewPaneDisplayMode>
              </wst:EqualsStateTrigger.EqualTo>
            </wst:EqualsStateTrigger>
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="MyNavigationView.FooterMenuItemsSource"
                    Value="{x:Bind _footerItemsForLeft}" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1060" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="MyNavigationView.FooterMenuItemsSource"
                    Value="{x:Bind _footerItemsForLeft}" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>

      <!-- ファイルオープンなど時間の掛かる操作時に他アクションを阻害する壁の表示切替 -->
      <VisualStateGroup>
        <VisualState x:Name="VS_HideBusyWall">
          <VisualState.Storyboard>
            <Storyboard>
              <DoubleAnimation Duration="0:0:0.175"
                               To="0.0"
                               Storyboard.TargetName="BusyWall"
                               Storyboard.TargetProperty="Opacity"
                               />
            </Storyboard>
          </VisualState.Storyboard>
          <VisualState.Setters>
            <Setter Target="BusyWall.Visibility" Value="Collapsed" />
            <Setter Target="BusyWall.IsHitTestVisible" Value="False" />
          </VisualState.Setters>
        </VisualState>
        <VisualState x:Name="VS_ShowBusyWall">
          <VisualState.Storyboard>
            <Storyboard>
              <DoubleAnimation Duration="0:0:0.175"
                               BeginTime="{x:Bind _busyWallDisplayDelayTime}"
                               To="1.0"
                               Storyboard.TargetName="BusyWall"
                               Storyboard.TargetProperty="Opacity"
                               />
            </Storyboard>
          </VisualState.Storyboard>
          <VisualState.Setters>
            <Setter Target="BusyWall.Visibility" Value="Visible" />
            <Setter Target="BusyWall.IsHitTestVisible" Value="True" />
            <Setter Target="BusyWall_ProgressRing.IsActive" Value="True" />
          </VisualState.Setters>
        </VisualState>
        <VisualState x:Name="VS_ShowBusyWall_WithoutCancel">
          <VisualState.Storyboard>
            <Storyboard>
              <DoubleAnimation Duration="0:0:0.175"
                               BeginTime="{x:Bind _busyWallDisplayDelayTime}"
                               To="1.0"
                               Storyboard.TargetName="BusyWall"
                               Storyboard.TargetProperty="Opacity"
                               />
            </Storyboard>
          </VisualState.Storyboard>
          <VisualState.Setters>
            <Setter Target="BusyWall.Visibility" Value="Visible" />
            <Setter Target="BusyWall.IsHitTestVisible" Value="True" />
            <Setter Target="BusyWall_ProgressRing.IsActive" Value="True" />
            <Setter Target="BusyWallCancelButton.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
      
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1060" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="820" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="610" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="MyNavigationView.PaneDisplayMode"
                    Value="Top" />
            <Setter Target="TitleIconAndTextContainer_Wide.Visibility"
                    Value="Collapsed" />
            <Setter Target="TitleIconAndTextContainer_Nallow.Visibility"
                    Value="Visible" />

            <Setter Target="TitlebarContent.Visibility"
                    Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>

      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind _vm.ApplicationSettings.IsAppMenuShowWithLeft, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="MyNavigationView.PaneDisplayMode"
                    Value="Top" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="610" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="MyNavigationView.PaneDisplayMode"
                    Value="Top" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>

      <!-- サイドメニュー表示時に戻るボタン・アプリアイコンのアラインをサイドペインとコンテンツエリアの境界に合わせる -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind _vm.ApplicationSettings.IsAppMenuShowWithLeft, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
            <wst:EqualsStateTrigger Value="{Binding ElementName=ViewerFrame, Path=Visibility}">
              <wst:EqualsStateTrigger.EqualTo>
                <Visibility>Visible</Visibility>
              </wst:EqualsStateTrigger.EqualTo>
            </wst:EqualsStateTrigger>
          </VisualState.StateTriggers>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="920" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="GoBackButton.Margin"
                    Value="144 0 8 0" />
          </VisualState.Setters>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
        </VisualState>
      </VisualStateGroup>

      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <wst:EqualsStateTrigger Value="{x:Bind MyNavigationView.IsPaneVisible, Mode=OneWay}" EqualTo="False" />
          </VisualState.StateTriggers>
        </VisualState>
        <VisualState>
          <VisualState.StateTriggers>
            <wst:DeviceFamilyStateTrigger DeviceFamily="Xbox" />
            <StateTrigger IsActive="{StaticResource DebugTVMode}" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="NavigationViewHeader.Padding" Value="48 0 0 0" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>

      <!-- フルスクリーン -->
      <VisualStateGroup>
        <VisualState>
          <VisualState.StateTriggers>
            <StateTrigger IsActive="{x:Bind NowShowTitlebarInFullScreen, Mode=OneWay}" />
          </VisualState.StateTriggers>
          <VisualState.Storyboard>
